<UserControl x:Class="BetterGenshinImpact.View.Controls.Markdown.MarkdownView"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:markdown="clr-namespace:BetterGenshinImpact.View.Controls.Markdown"
             Background="Transparent">
    <Grid Background="{Binding Background, ElementName=Root}">
        <FlowDocumentScrollViewer x:Name="DocumentViewer"
                                  Padding="0"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  HorizontalScrollBarVisibility="Auto"
                                  IsSelectionEnabled="True"
                                  IsToolBarVisible="False"
                                  VerticalScrollBarVisibility="Auto" />

        <Border Padding="24"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="{DynamicResource MarkdownCodeBackgroundBrush}"
                BorderBrush="{DynamicResource MarkdownBorderBrush}"
                BorderThickness="1"
                CornerRadius="8">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding State, ElementName=Root}"
                                     Value="{x:Static markdown:MarkdownViewState.Failed}">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <StackPanel MaxWidth="560">
                <TextBlock FontSize="16"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource MarkdownErrorBrush}"
                           Text="Markdown 加载失败" />
                <TextBlock Margin="0,8,0,0"
                           Foreground="{DynamicResource MarkdownSecondaryForegroundBrush}"
                           Text="{Binding LastError.Message, ElementName=Root}"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <Border Padding="16"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="{DynamicResource MarkdownCodeBackgroundBrush}"
                CornerRadius="8">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsLoading, ElementName=Root}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <StackPanel Orientation="Horizontal">
                <ProgressBar Width="72"
                             Height="4"
                             Margin="0,0,12,0"
                             VerticalAlignment="Center"
                             IsIndeterminate="True" />
                <TextBlock VerticalAlignment="Center"
                           Foreground="{DynamicResource MarkdownSecondaryForegroundBrush}"
                           Text="正在渲染 Markdown…" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
