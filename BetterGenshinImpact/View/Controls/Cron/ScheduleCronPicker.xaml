<UserControl x:Class="BetterGenshinImpact.View.Controls.Cron.ScheduleCronPicker"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:BetterGenshinImpact.View.Controls.Cron"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             mc:Ignorable="d"
             d:DesignHeight="40"
             d:DesignWidth="420"
             x:Name="Root">
    <Grid>
        <ToggleButton x:Name="MainToggle"
                      HorizontalAlignment="Stretch"
                      HorizontalContentAlignment="Stretch"
                      Padding="12,6"
                      Height="34"
                      Background="{DynamicResource ControlFillColorDefaultBrush}"
                      BorderBrush="{DynamicResource SurfaceStrokeColorDefaultBrush}"
                      BorderThickness="1"
                      IsChecked="{Binding ViewModel.IsPopupOpen, Mode=TwoWay}">
            <ToggleButton.Template>
                <ControlTemplate TargetType="ToggleButton">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding ViewModel.DisplayText}"
                                       VerticalAlignment="Center"
                                       Margin="5,0,0,0"
                                       TextTrimming="CharacterEllipsis" />
                            <TextBlock Grid.Column="1"
                                       Text="▼"
                                       FontSize="10"
                                       VerticalAlignment="Center"
                                       Margin="0,0,10,0" />
                        </Grid>
                    </Border>
                </ControlTemplate>
            </ToggleButton.Template>
        </ToggleButton>

        <Popup IsOpen="{Binding ViewModel.IsPopupOpen, Mode=TwoWay}"
               PlacementTarget="{Binding ElementName=MainToggle}"
               StaysOpen="False"
               AllowsTransparency="True"
               PopupAnimation="Slide">
            <Border Background="{DynamicResource ApplicationBackgroundBrush}"
                    BorderBrush="{DynamicResource SurfaceStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Margin="0,4,0,0"
                    Padding="12"
                    Width="420">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10"
                                      ShadowDepth="2"
                                      Direction="270"
                                      Color="Black"
                                      Opacity="0.2" />
                </Border.Effect>

                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <ui:TextBlock Text="周期"
                                      Grid.Column="0"
                                      VerticalAlignment="Center"
                                      Margin="0,0,10,0" />
                        <ComboBox Grid.Column="1"
                                  SelectedValue="{Binding ViewModel.SelectedMode, Mode=TwoWay}"
                                  SelectedValuePath="Tag">
                            <ComboBoxItem Content="每日" Tag="{x:Static local:ScheduleMode.Daily}" />
                            <ComboBoxItem Content="每周" Tag="{x:Static local:ScheduleMode.Weekly}" />
                        </ComboBox>
                    </Grid>

                    <StackPanel Margin="0,12,0,0"
                                Visibility="{Binding ViewModel.SelectedMode, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter=Weekly}">
                        <ui:TextBlock Text="星期" Margin="0,0,0,6" />
                        <UniformGrid Columns="7">
                            <CheckBox Content="一" IsChecked="{Binding ViewModel.Monday, Mode=TwoWay}" HorizontalAlignment="Center" />
                            <CheckBox Content="二" IsChecked="{Binding ViewModel.Tuesday, Mode=TwoWay}" HorizontalAlignment="Center" />
                            <CheckBox Content="三" IsChecked="{Binding ViewModel.Wednesday, Mode=TwoWay}" HorizontalAlignment="Center" />
                            <CheckBox Content="四" IsChecked="{Binding ViewModel.Thursday, Mode=TwoWay}" HorizontalAlignment="Center" />
                            <CheckBox Content="五" IsChecked="{Binding ViewModel.Friday, Mode=TwoWay}" HorizontalAlignment="Center" />
                            <CheckBox Content="六" IsChecked="{Binding ViewModel.Saturday, Mode=TwoWay}" HorizontalAlignment="Center" />
                            <CheckBox Content="日" IsChecked="{Binding ViewModel.Sunday, Mode=TwoWay}" HorizontalAlignment="Center" />
                        </UniformGrid>
                    </StackPanel>

                    <StackPanel Margin="0,12,0,0">
                        <ui:TextBlock Text="时间" Margin="0,0,0,6" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <ComboBox Grid.Column="0"
                                      ItemsSource="{Binding ViewModel.Hours}"
                                      SelectedItem="{Binding ViewModel.Hour, Mode=TwoWay}" />
                            <ui:TextBlock Grid.Column="1" Text=":" VerticalAlignment="Center" Margin="6,0" />
                            <ComboBox Grid.Column="2"
                                      ItemsSource="{Binding ViewModel.Minutes}"
                                      SelectedItem="{Binding ViewModel.Minute, Mode=TwoWay}" />
                            <ui:TextBlock Grid.Column="3" Text=":" VerticalAlignment="Center" Margin="6,0" />
                            <ComboBox Grid.Column="4"
                                      ItemsSource="{Binding ViewModel.Seconds}"
                                      SelectedItem="{Binding ViewModel.Second, Mode=TwoWay}" />
                        </Grid>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Margin="0,14,0,0">
                        <ui:Button Content="取消"
                                   Appearance="Secondary"
                                   Command="{Binding ViewModel.CancelCommand}"
                                   MinWidth="80"
                                   Margin="0,0,8,0" />
                        <ui:Button Content="应用"
                                   Appearance="Primary"
                                   Command="{Binding ViewModel.ApplyCommand}"
                                   MinWidth="80" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Popup>
    </Grid>
</UserControl>
