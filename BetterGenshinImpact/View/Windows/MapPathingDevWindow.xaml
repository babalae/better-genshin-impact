<ui:FluentWindow x:Class="BetterGenshinImpact.View.Windows.MapPathingDevWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:behavior="clr-namespace:BetterGenshinImpact.View.Behavior"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:windows="clr-namespace:BetterGenshinImpact.ViewModel.Windows"
                 Width="900"
                 Height="640"
                 MinWidth="680"
                 MinHeight="500"
                 d:DataContext="{d:DesignInstance Type=windows:MapPathingDevViewModel}"
                 ui:Design.Background="{DynamicResource ApplicationBackgroundBrush}"
                 ui:Design.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                 behavior:AutoTranslateInterceptor.EnableAutoTranslate="True"
                 ExtendsContentIntoTitleBar="True"
                 FontFamily="{DynamicResource TextThemeFontFamily}"
                 WindowStartupLocation="CenterOwner"
                 WindowBackdropType="Auto"
                 mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar Title="地图追踪开发者工具">
            <ui:TitleBar.Icon>
                <ui:ImageIcon Source="pack://application:,,,/Resources/Images/logo.png" />
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid Margin="14">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <ui:Border Grid.Row="0"
                           Padding="12"
                           Background="{DynamicResource CardBackground}"
                           BorderBrush="{DynamicResource CardBorderBrush}"
                           BorderThickness="1"
                           CornerRadius="8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="170" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <ui:TextBlock FontTypography="BodyStrong" Text="地图工具" />
                            <ui:TextBlock Margin="0,4,0,10"
                                          Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}"
                                          Text="选择录制和规划所在地图。" />
                        </StackPanel>

                        <Grid Grid.Column="1">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <ComboBox Grid.Row="0"
                                      Grid.Column="0"
                                      MinWidth="220"
                                      Margin="0,0,10,0"
                                      DisplayMemberPath="DisplayName"
                                      ItemsSource="{Binding MapTypeItems}"
                                      SelectedValue="{Binding DevConfig.RecordMapName, Mode=TwoWay}"
                                      SelectedValuePath="EnumName" />
                            <ui:Button Grid.Row="0"
                                       Grid.Column="1"
                                       Margin="0,0,10,0"
                                       Command="{Binding OpenMapViewerCommand}"
                                       Content="实时追踪地图" />
                            <ui:Button Grid.Row="0"
                                       Grid.Column="2"
                                       Margin="0,0,10,0"
                                       Command="{Binding OpenMapEditorCommand}"
                                       Content="录制编辑器" />
                            <ui:Button Grid.Row="0"
                                       Grid.Column="3"
                                       Margin="0,0,10,0"
                                       Command="{Binding RefreshDiagnosticsLiteCommand}"
                                       Content="刷新" />
                            <ui:Button Grid.Row="0"
                                       Grid.Column="4"
                                       Margin="0,0,10,0"
                                       Command="{Binding RefreshGraphDiagnosticsCommand}"
                                       Content="查询附近" />
                            <ui:Button Grid.Row="0"
                                       Grid.Column="5"
                                       Margin="0,0,10,0"
                                       Command="{Binding RebuildGraphCommand}"
                                       Content="重建路网" />
                            <ui:Button Grid.Row="0"
                                       Grid.Column="6"
                                       Command="{Binding OpenRoutesFolderCommand}"
                                       Content="目录" />
                            <ui:TextBlock Grid.Row="1"
                                          Grid.ColumnSpan="7"
                                          Margin="0,10,0,0"
                                          Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}"
                                          Text="{Binding GraphFilePath}"
                                          TextTrimming="CharacterEllipsis" />
                        </Grid>
                    </Grid>
                </ui:Border>

                <ui:Border Grid.Row="1"
                           Margin="0,10,0,0"
                           Padding="12"
                           Background="{DynamicResource CardBackground}"
                           BorderBrush="{DynamicResource CardBorderBrush}"
                           BorderThickness="1"
                           CornerRadius="8">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="170" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.RowSpan="4" Grid.Column="0">
                            <ui:TextBlock FontTypography="BodyStrong" Text="路网规划测试" />
                            <ui:TextBlock Margin="0,4,0,0"
                                          Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}"
                                          Text="规划结果会同步到实时追踪地图。" 
                                          TextWrapping="Wrap" />
                        </StackPanel>

                        <Grid Grid.Row="0" Grid.Column="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="18" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                <DockPanel Margin="0,0,0,4">
                                    <ui:TextBlock Text="当前 X" />
                                </DockPanel>
                                <ui:TextBox Text="{Binding CurrentImageX, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="0,0,10,0">
                                <DockPanel Margin="0,0,0,4">
                                    <ui:TextBlock Text="当前 Y" />
                                </DockPanel>
                                <ui:TextBox Text="{Binding CurrentImageY, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Grid.Column="3" Margin="0,0,10,0">
                                <ui:TextBlock Margin="0,0,0,4" Text="目标 X" />
                                <ui:TextBox Text="{Binding TargetImageX, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Grid.Column="4">
                                <ui:TextBlock Margin="0,0,0,4" Text="目标 Y" />
                                <ui:TextBox Text="{Binding TargetImageY, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </Grid>

                        <Grid Grid.Row="1" Grid.Column="1" Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                <ui:TextBlock Margin="0,0,0,4" Text="终点模式覆盖" />
                                <ui:TextBox PlaceholderText="空=沿用最后一条边"
                                            Text="{Binding TargetMoveMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="0,0,10,0">
                                <ui:TextBlock Margin="0,0,0,4" Text="目标动作" />
                                <ui:TextBox Text="{Binding TargetAction, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <ui:Button Grid.Column="2"
                                       MinWidth="110"
                                       Margin="0,20,0,0"
                                       Command="{Binding PlanRouteCommand}"
                                       Content="规划路线" />
                        </Grid>

                        <WrapPanel Grid.Row="2"
                                   Grid.Column="1"
                                   Margin="0,12,0,0"
                                   VerticalAlignment="Center">
                            <CheckBox Margin="0,0,18,0"
                                      Content="跟随当前坐标"
                                      IsChecked="{Binding FollowCurrentPosition, Mode=TwoWay}" />
                            <CheckBox Margin="0,0,18,0"
                                      Content="允许传送"
                                      IsChecked="{Binding AllowTeleport, Mode=TwoWay}" />
                            <CheckBox Margin="0,0,18,0"
                                      Content="未知起点连接"
                                      IsChecked="{Binding AllowUnknownStartConnector, Mode=TwoWay}" />
                            <CheckBox Margin="0,0,18,0"
                                      Content="未知目标连接"
                                      IsChecked="{Binding AllowUnknownTargetConnector, Mode=TwoWay}" />
                            <CheckBox Content="允许禁用边"
                                      IsChecked="{Binding AllowDisabledEdges, Mode=TwoWay}" />
                        </WrapPanel>

                        <StackPanel Grid.Row="3" Grid.Column="1" Margin="0,14,0,0">
                            <ui:TextBlock FontTypography="BodyStrong"
                                          Text="{Binding PlanSummary}"
                                          TextWrapping="Wrap" />
                            <ui:TextBlock Margin="0,4,0,0"
                                          Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}"
                                          Text="{Binding GraphStatus}"
                                          TextWrapping="Wrap" />
                            <ui:TextBlock Margin="0,4,0,0"
                                          Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}"
                                          Text="{Binding TargetPickSummary}"
                                          TextWrapping="Wrap" />
                            <ui:TextBlock Margin="0,4,0,0"
                                          Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}"
                                          Text="{Binding GraphSummary}"
                                          TextWrapping="Wrap" />
                            <ui:TextBlock Margin="0,4,0,0"
                                          Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}"
                                          Text="{Binding HealthSummary}"
                                          TextWrapping="Wrap" />
                        </StackPanel>
                    </Grid>
                </ui:Border>

                <ui:Border Grid.Row="2"
                           Margin="0,10,0,0"
                           Padding="8"
                           Background="{DynamicResource CardBackground}"
                           BorderBrush="{DynamicResource CardBorderBrush}"
                           BorderThickness="1"
                           CornerRadius="8">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <ui:TextBlock Margin="6,4,0,10"
                                      FontTypography="BodyStrong"
                                      Text="路网调试数据" />
                        <TabControl Grid.Row="1" MinHeight="180">
                            <TabItem Header="规划边">
                                <DataGrid AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          CanUserDeleteRows="False"
                                          HeadersVisibility="Column"
                                          IsReadOnly="True"
                                          ItemsSource="{Binding PlannedEdges}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Width="48" Binding="{Binding Index}" Header="#" />
                                        <DataGridTextColumn Width="110" Binding="{Binding FromNodeId}" Header="From" />
                                        <DataGridTextColumn Width="110" Binding="{Binding ToNodeId}" Header="To" />
                                        <DataGridTextColumn Width="80" Binding="{Binding Cost, StringFormat=F2}" Header="Cost" />
                                        <DataGridTextColumn Width="90" Binding="{Binding MoveMode}" Header="MoveMode" />
                                        <DataGridTextColumn Width="130" Binding="{Binding Action}" Header="Action" />
                                        <DataGridTextColumn Width="100" Binding="{Binding HealthStatus}" Header="Health" />
                                        <DataGridCheckBoxColumn Width="80" Binding="{Binding IsSyntheticReverse}" Header="Reverse" />
                                        <DataGridCheckBoxColumn Width="80" Binding="{Binding IsBidirectionalCandidate}" Header="BiDir" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </TabItem>
                            <TabItem Header="附近节点">
                                <DataGrid AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          CanUserDeleteRows="False"
                                          HeadersVisibility="Column"
                                          IsReadOnly="True"
                                          ItemsSource="{Binding NearbyNodes}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Width="140" Binding="{Binding NodeId}" Header="Node" />
                                        <DataGridTextColumn Width="90" Binding="{Binding X, StringFormat=F1}" Header="X" />
                                        <DataGridTextColumn Width="90" Binding="{Binding Y, StringFormat=F1}" Header="Y" />
                                        <DataGridTextColumn Width="90" Binding="{Binding Distance, StringFormat=F1}" Header="Distance" />
                                        <DataGridTextColumn Width="80" Binding="{Binding Anchors}" Header="Anchors" />
                                        <DataGridTextColumn Width="90" Binding="{Binding Resources}" Header="Resources" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </TabItem>
                            <TabItem Header="附近边">
                                <DataGrid AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          CanUserDeleteRows="False"
                                          HeadersVisibility="Column"
                                          IsReadOnly="True"
                                          ItemsSource="{Binding NearbyEdges}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Width="140" Binding="{Binding EdgeId}" Header="Edge" />
                                        <DataGridTextColumn Width="90" Binding="{Binding Distance, StringFormat=F1}" Header="Distance" />
                                        <DataGridTextColumn Width="80" Binding="{Binding Cost, StringFormat=F2}" Header="Cost" />
                                        <DataGridTextColumn Width="90" Binding="{Binding MoveMode}" Header="MoveMode" />
                                        <DataGridTextColumn Width="130" Binding="{Binding Action}" Header="Action" />
                                        <DataGridTextColumn Width="100" Binding="{Binding HealthStatus}" Header="Health" />
                                        <DataGridCheckBoxColumn Width="80" Binding="{Binding Reverse}" Header="Reverse" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </TabItem>
                            <TabItem Header="健康记录">
                                <DataGrid AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          CanUserDeleteRows="False"
                                          HeadersVisibility="Column"
                                          IsReadOnly="True"
                                          ItemsSource="{Binding HealthRows}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Width="140" Binding="{Binding SegmentId}" Header="Segment" />
                                        <DataGridTextColumn Width="90" Binding="{Binding Status}" Header="Status" />
                                        <DataGridTextColumn Width="70" Binding="{Binding Success}" Header="Success" />
                                        <DataGridTextColumn Width="70" Binding="{Binding Failure}" Header="Failure" />
                                        <DataGridTextColumn Width="70" Binding="{Binding Rate, StringFormat=P0}" Header="Rate" />
                                        <DataGridTextColumn Width="90" Binding="{Binding MoveMode}" Header="MoveMode" />
                                        <DataGridTextColumn Width="130" Binding="{Binding Action}" Header="Action" />
                                        <DataGridTextColumn Width="220" Binding="{Binding LastFailure}" Header="LastFailure" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </TabItem>
                        </TabControl>
                    </Grid>
                </ui:Border>
            </Grid>
        </ScrollViewer>
    </Grid>
</ui:FluentWindow>
