<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
    <SolidColorBrush x:Key="MapEditorPanelBrush" Color="#E812171B" />
    <SolidColorBrush x:Key="MapEditorCardBrush" Color="#D8172026" />
    <SolidColorBrush x:Key="MapEditorInsetBrush" Color="#99111822" />
    <SolidColorBrush x:Key="MapEditorStrokeBrush" Color="#33485761" />
    <SolidColorBrush x:Key="MapEditorAccentBrush" Color="#23C8D2" />
    <SolidColorBrush x:Key="MapEditorTextPrimaryBrush" Color="#F3F7FA" />
    <SolidColorBrush x:Key="MapEditorTextSecondaryBrush" Color="#C7D2DA" />

    <Style x:Key="DevToolDialogContentStyle" TargetType="Border">
        <Setter Property="Margin" Value="16" />
        <Setter Property="Padding" Value="16" />
        <Setter Property="Background" Value="{StaticResource MapEditorPanelBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource MapEditorStrokeBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="6" />
    </Style>

    <Style x:Key="DevToolDialogCardStyle" TargetType="Border">
        <Setter Property="Padding" Value="12" />
        <Setter Property="Background" Value="{StaticResource MapEditorCardBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource MapEditorStrokeBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="6" />
    </Style>

    <Style x:Key="DevToolDialogInsetCardStyle" TargetType="Border">
        <Setter Property="Padding" Value="8" />
        <Setter Property="Background" Value="{StaticResource MapEditorInsetBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource MapEditorStrokeBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="4" />
    </Style>

    <Style x:Key="DevToolDialogSectionTitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="15" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource MapEditorTextPrimaryBrush}" />
    </Style>

    <Style x:Key="DevToolDialogCaptionStyle" TargetType="TextBlock">
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Foreground" Value="{StaticResource MapEditorTextSecondaryBrush}" />
    </Style>

    <Style x:Key="DevToolDialogValueStyle" TargetType="TextBlock">
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Foreground" Value="{StaticResource MapEditorTextPrimaryBrush}" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
    </Style>

    <Style TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource MapEditorTextPrimaryBrush}" />
    </Style>

    <Style TargetType="ui:TextBox">
        <Setter Property="Height" Value="34" />
        <Setter Property="MinHeight" Value="34" />
        <Setter Property="Padding" Value="8,0" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Background" Value="{StaticResource MapEditorInsetBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource MapEditorStrokeBrush}" />
        <Setter Property="Foreground" Value="{StaticResource MapEditorTextPrimaryBrush}" />
    </Style>

    <Style TargetType="ComboBoxItem">
        <Setter Property="Foreground" Value="{StaticResource MapEditorTextPrimaryBrush}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="MinHeight" Value="30" />
        <Setter Property="Padding" Value="10,0" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBoxItem">
                    <Border x:Name="Root"
                            Margin="4,1"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4">
                        <ContentPresenter Margin="{TemplateBinding Padding}"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="#26313B" />
                        </Trigger>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="#26313B" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="#B0147884" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="ComboBox">
        <Setter Property="Height" Value="34" />
        <Setter Property="MinHeight" Value="34" />
        <Setter Property="Padding" Value="8,0" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Foreground" Value="{StaticResource MapEditorTextPrimaryBrush}" />
        <Setter Property="Background" Value="{StaticResource MapEditorInsetBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource MapEditorStrokeBrush}" />
        <Setter Property="MaxDropDownHeight" Value="260" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid>
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="4">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="30" />
                                </Grid.ColumnDefinitions>
                                <ContentPresenter Margin="{TemplateBinding Padding}"
                                                  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                                  Content="{TemplateBinding SelectionBoxItem}"
                                                  ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                  IsHitTestVisible="False"
                                                  RecognizesAccessKey="True" />
                                <ui:SymbolIcon Grid.Column="1"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               FontSize="14"
                                               Foreground="{StaticResource MapEditorTextSecondaryBrush}"
                                               Symbol="ChevronDown16" />
                            </Grid>
                        </Border>
                        <Popup x:Name="PART_Popup"
                               AllowsTransparency="True"
                               Focusable="False"
                               IsOpen="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}"
                               Placement="Bottom">
                            <Border MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                    MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                    Margin="0,4,0,0"
                                    Padding="2"
                                    Background="#FF1A2025"
                                    BorderBrush="{StaticResource MapEditorStrokeBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6">
                                <ScrollViewer CanContentScroll="True"
                                              HorizontalScrollBarVisibility="Disabled"
                                              VerticalScrollBarVisibility="Auto">
                                    <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained" />
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="BorderBrush" Value="#6639DCEB" />
                        </Trigger>
                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                            <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource MapEditorAccentBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.55" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="CheckBox">
        <Setter Property="Foreground" Value="{StaticResource MapEditorTextPrimaryBrush}" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="{TemplateBinding VerticalContentAlignment}">
                        <Border x:Name="Box"
                                Width="18"
                                Height="18"
                                Margin="0,0,8,0"
                                Background="{StaticResource MapEditorInsetBrush}"
                                BorderBrush="{StaticResource MapEditorStrokeBrush}"
                                BorderThickness="1"
                                CornerRadius="3">
                            <ui:SymbolIcon x:Name="CheckIcon"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontSize="12"
                                           Foreground="#FF071114"
                                           Opacity="0"
                                           Symbol="Checkmark12" />
                        </Border>
                        <ContentPresenter VerticalAlignment="Center"
                                          Content="{TemplateBinding Content}"
                                          RecognizesAccessKey="True" />
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <Trigger Property="Content" Value="{x:Null}">
                            <Setter TargetName="Box" Property="Margin" Value="0" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Box" Property="BorderBrush" Value="#6639DCEB" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Box" Property="Background" Value="{StaticResource MapEditorAccentBrush}" />
                            <Setter TargetName="Box" Property="BorderBrush" Value="{StaticResource MapEditorAccentBrush}" />
                            <Setter TargetName="CheckIcon" Property="Opacity" Value="1" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.55" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="ui:Button">
        <Setter Property="MinHeight" Value="32" />
        <Setter Property="Foreground" Value="{StaticResource MapEditorTextPrimaryBrush}" />
    </Style>
</ResourceDictionary>
