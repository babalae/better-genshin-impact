                                                                    <CheckBox Margin="4,5"
                                                                              VerticalContentAlignment="Center"
                                                                              Content="{Binding DisplayName}"
                                                                              Foreground="{StaticResource MapEditorTextPrimaryBrush}"
                                                                              IsChecked="{Binding IsSelected, Mode=TwoWay}" />
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </ScrollViewer>
                                                    <ui:Button Height="30"
                                                               Margin="4,8,4,0"
                                                               HorizontalAlignment="Stretch"
                                                               Command="{Binding ClearWaypointFilterCommand}"
                                                               Content="清除筛选" />
                                                </StackPanel>
                                            </Border>
                                        </Popup>
                                    </Grid>
                                </StackPanel>
                                <StackPanel Grid.Column="2" Orientation="Horizontal">
                                    <ui:Button x:Name="CombatScriptManagerButton"
                                               Width="34"
                                               Height="34"
                                               Padding="0"
                                               Command="{Binding OpenCombatScriptManagerCommand}"
                                               Icon="{ui:SymbolIcon Wrench24}"
                                               ToolTip="战斗策略管理" />
                                    <ui:Button Width="34"
                                               Height="34"
                                               Margin="4,0,0,0"
                                               Padding="0"
                                               Command="{Binding UndoRecorderEditCommand}"
                                               Icon="{ui:SymbolIcon ArrowUndo24}"
                                               ToolTip="撤销" />
                                    <ui:Button Width="34"
                                               Height="34"
                                               Margin="4,0,0,0"
                                               Padding="0"
                                               Command="{Binding RedoRecorderEditCommand}"
                                               Icon="{ui:SymbolIcon ArrowRedo24}"
                                               ToolTip="重做" />
                                    <ui:Button Width="34"
                                               Height="34"
                                               Margin="4,0,0,0"
                                               Padding="0"
                                               Command="{Binding ClearRecordedWaypointsCommand}"
                                               Foreground="{StaticResource MapEditorDangerBrush}"
                                               Icon="{ui:SymbolIcon Delete24}"
                                               ToolTip="清空路线" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Popup AllowsTransparency="True"
                               DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}"
                               HorizontalOffset="-320"
                               IsOpen="{Binding IsCombatScriptManagerOpen, Mode=TwoWay}"
                               Placement="Bottom"
                               PlacementTarget="{Binding ElementName=CombatScriptManagerButton}"
                               StaysOpen="False">
                            <Border Width="430"
                                    Padding="14"
                                    Background="#FF1A2025"
                                    BorderBrush="{StaticResource MapEditorStrokeBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock FontWeight="SemiBold" Text="战斗策略管理" />

                                    <Grid Grid.Row="1"
                                          Margin="0,12,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <ui:TextBox Height="34"
                                                    PlaceholderText="策略参数"
                                                    Style="{StaticResource FormTextBoxStyle}"
                                                    Text="{Binding NewCombatScriptValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <CheckBox Grid.Column="2"
                                                  VerticalAlignment="Center"
                                                  Content="默认"
                                                  Foreground="{StaticResource MapEditorTextPrimaryBrush}"
                                                  IsChecked="{Binding NewCombatScriptIsDefault, Mode=TwoWay}" />
                                        <ui:Button Grid.Column="4"
                                                   Height="34"
                                                   Command="{Binding AddCombatScriptCommand}"
                                                   Content="添加"
                                                   Icon="{ui:SymbolIcon Add24}" />
                                    </Grid>

                                    <ListBox Grid.Row="2"
                                             MinHeight="160"
                                             MaxHeight="260"
                                             ItemContainerStyle="{StaticResource MapEditorListBoxItemStyle}"
                                             ItemsSource="{Binding CombatScripts}"
                                             Style="{StaticResource MapEditorListBoxStyle}">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="8" />
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="8" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock VerticalAlignment="Center"
                                                               Text="{Binding Value}"
                                                               TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Grid.Column="1"
                                                               VerticalAlignment="Center"
                                                               Foreground="{StaticResource MapEditorWarningBrush}"
                                                               Text="{Binding DefaultText}" />
                                                    <ui:Button Grid.Column="3"
                                                               Height="28"
                                                               Command="{Binding DataContext.SetDefaultCombatScriptCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                               CommandParameter="{Binding}"
                                                               Content="设默认" />
                                                    <ui:Button Grid.Column="5"
                                                               Width="30"
                                                               Height="28"
                                                               Padding="0"
                                                               Command="{Binding DataContext.DeleteCombatScriptCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                               CommandParameter="{Binding}"
                                                               Foreground="{StaticResource MapEditorDangerBrush}"
                                                               Icon="{ui:SymbolIcon Delete24}" />
                                                </Grid>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>

                                    <ui:Button Grid.Row="3"
                                               Width="96"
                                               Height="32"
                                               Margin="0,12,0,0"
                                               HorizontalAlignment="Right"
                                               Command="{Binding CloseCombatScriptManagerCommand}"
                                               Content="关闭"
                                               Icon="{ui:SymbolIcon Dismiss24}" />
                                </Grid>
                            </Border>
                        </Popup>

                        <Grid Grid.Row="1">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Border Background="{StaticResource MapEditorCardBrush}"
                                    BorderBrush="{StaticResource MapEditorStrokeBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Visibility="{Binding RecordedWaypointEmptyVisibility}">
                                <TextBlock HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Style="{StaticResource CaptionTextStyle}"
                                           Text="{Binding RouteEmptyStatusText}" />
                            </Border>

                            <DataGrid x:Name="RecordedWaypointGrid"
                                      Grid.Row="0"
                                      MinHeight="180"
                                      AutoGenerateColumns="False"
                                      Background="{StaticResource MapEditorCardBrush}"
                                      BorderBrush="{StaticResource MapEditorStrokeBrush}"
                                      BorderThickness="1"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      ColumnHeaderHeight="32"
                                      GridLinesVisibility="None"
                                      HeadersVisibility="Column"
                                      IsReadOnly="True"
                                      ItemsSource="{Binding RecordedWaypointView}"
                                      RowHeight="34"
                                      SelectedItem="{Binding SelectedRecordedWaypoint, Mode=TwoWay}"
                                      SelectionMode="Extended"
                                      SelectionUnit="FullRow"
                                      PreviewMouseRightButtonDown="RecordedWaypointGrid_PreviewMouseRightButtonDown"
                                      Visibility="{Binding RecordedWaypointListVisibility}">
                                <DataGrid.RowStyle>
                                    <Style TargetType="DataGridRow">
                                        <Setter Property="Tag" Value="{Binding DataContext, RelativeSource={RelativeSource AncestorType=DataGrid}}" />
                                        <Setter Property="Background" Value="Transparent" />
                                        <Setter Property="BorderBrush" Value="{StaticResource MapEditorGridLineBrush}" />
                                        <Setter Property="BorderThickness" Value="0,0,0,1" />
                                        <Setter Property="Foreground" Value="{StaticResource MapEditorTextPrimaryBrush}" />
                                        <Setter Property="ContextMenu">
                                            <Setter.Value>
                                                <ContextMenu>
                                                    <ui:MenuItem Command="{Binding PlacementTarget.Tag.RunRecordingFromWaypointCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                 CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                 Header="从此点运行"
                                                                 Icon="{ui:SymbolIcon Play24}" />
                                                    <ui:MenuItem Command="{Binding PlacementTarget.Tag.ToggleWaypointLockCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                 CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                 Header="设为插入位置"
                                                                 Icon="{ui:SymbolIcon Location24}" />
                                                    <ui:MenuItem Command="{Binding PlacementTarget.Tag.OpenWaypointAdvancedEditorCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                 CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                 Header="高级信息"
                                                                 Icon="{ui:SymbolIcon Settings24}" />
                                                    <Separator />
                                                    <ui:MenuItem Command="{Binding PlacementTarget.Tag.CopyWaypointSelectionCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                 Header="复制选中"
                                                                 Icon="{ui:SymbolIcon Copy24}"
                                                                 InputGestureText="Ctrl+C" />
                                                    <ui:MenuItem Command="{Binding PlacementTarget.Tag.CutWaypointSelectionCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                 Header="剪切选中"
                                                                 Icon="{ui:SymbolIcon Cut24}"
                                                                 InputGestureText="Ctrl+X" />
                                                    <ui:MenuItem Command="{Binding PlacementTarget.Tag.PasteWaypointSelectionCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                 Header="粘贴到选中后"
                                                                 Icon="{ui:SymbolIcon ClipboardPaste24}"
                                                                 InputGestureText="Ctrl+V" />
                                                    <ui:MenuItem Command="{Binding PlacementTarget.Tag.DuplicateWaypointSelectionCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                 Header="复制并插入"
                                                                 Icon="{ui:SymbolIcon CopyAdd24}"
                                                                 InputGestureText="Ctrl+D" />
                                                    <ui:MenuItem Command="{Binding PlacementTarget.Tag.DeleteWaypointSelectionCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                 Foreground="{StaticResource MapEditorDangerBrush}"
                                                                 Header="删除选中"
                                                                 Icon="{ui:SymbolIcon Delete24}"
                                                                 InputGestureText="Delete" />
                                                    <Separator />
                                                    <ui:MenuItem Command="{Binding PlacementTarget.Tag.MoveRecordedWaypointUpCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                 CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                 Header="上移"
                                                                 Icon="{ui:SymbolIcon ArrowUp24}" />
                                                    <ui:MenuItem Command="{Binding PlacementTarget.Tag.MoveRecordedWaypointDownCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                 CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                 Header="下移"
                                                                 Icon="{ui:SymbolIcon ArrowDown24}" />
                                                    <Separator />
                                                    <ui:MenuItem Command="{Binding PlacementTarget.Tag.ClearWaypointSelectionCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                 Header="取消选择"
                                                                 Icon="{ui:SymbolIcon Dismiss24}" />
                                                </ContextMenu>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#24147884" />
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="#B0147884" />
                                                <Setter Property="BorderBrush" Value="#6639DCEB" />
                                                <Setter Property="Foreground" Value="{StaticResource MapEditorAccentBrush}" />
                                            </Trigger>
                                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                <Setter Property="Background" Value="#B0147884" />
                                                <Setter Property="BorderBrush" Value="#6639DCEB" />
                                                <Setter Property="Foreground" Value="{StaticResource MapEditorAccentBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGrid.RowStyle>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Width="42"
                                                        Binding="{Binding Index}"
                                                        ElementStyle="{StaticResource WaypointGridTextStyle}"
                                                        Header="#" />
                                    <DataGridTemplateColumn Width="174" Header="坐标">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Grid Width="158"
                                                      Height="34"
                                                      HorizontalAlignment="Center">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="74" />
                                                        <ColumnDefinition Width="10" />
                                                        <ColumnDefinition Width="74" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Style="{StaticResource WaypointCoordinateTextStyle}"
                                                               Text="{Binding CoordinateXText}" />
                                                    <TextBlock Grid.Column="1"
                                                               Style="{StaticResource WaypointCoordinateSeparatorStyle}"
                                                               Text="," />
                                                    <TextBlock Grid.Column="2"
                                                               Style="{StaticResource WaypointCoordinateTextStyle}"
                                                               Text="{Binding CoordinateYText}" />
                                                </Grid>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Width="82" Header="类型">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <ComboBox ItemTemplate="{StaticResource WaypointGridOptionTemplate}"
                                                          ItemContainerStyle="{StaticResource MapEditorComboBoxItemStyle}"
                                                          ItemsSource="{Binding DataContext.WaypointTypeOptions, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                          SelectedValue="{Binding Type, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                          SelectedValuePath="Code"
                                                          Style="{StaticResource WaypointGridComboBoxStyle}"
                                                          ToolTip="点位类型" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Width="70" Header="移动">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <ComboBox ItemTemplate="{StaticResource WaypointGridOptionTemplate}"
                                                          ItemContainerStyle="{StaticResource MapEditorComboBoxItemStyle}"
                                                          ItemsSource="{Binding DataContext.MoveModeOptions, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                          SelectedValue="{Binding MoveMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                          SelectedValuePath="Code"
                                                          Style="{StaticResource WaypointGridComboBoxStyle}"
                                                          ToolTip="移动方式" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Width="*"
                                                            MinWidth="92"
                                                            Header="动作">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Click="WaypointActionSelectorButton_Click"
                                                        Content="{Binding ActionDisplayText}"
                                                        Style="{StaticResource WaypointGridSelectorButtonStyle}"
                                                        ToolTip="{Binding ActionParameterHint}" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Width="112" Header="操作">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel HorizontalAlignment="Center"
                                                            VerticalAlignment="Center"
                                                            Orientation="Horizontal">
                                                    <Button Command="{Binding DataContext.ToggleWaypointLockCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                            CommandParameter="{Binding}"
                                                            Style="{StaticResource WaypointGridActionButtonStyle}"
                                                            ToolTip="锁定插入位置：新增路线点会插入到该点之后">
                                                        <ui:SymbolIcon FontSize="14"
                                                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}">
                                                            <ui:SymbolIcon.Style>
                                                                <Style TargetType="ui:SymbolIcon">
                                                                    <Setter Property="Symbol" Value="LockOpen24" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsLocked}" Value="True">
                                                                            <Setter Property="Symbol" Value="LockClosed24" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </ui:SymbolIcon.Style>
                                                        </ui:SymbolIcon>
                                                    </Button>
                                                    <Button Margin="1,0,0,0"
                                                            Command="{Binding DataContext.OpenWaypointAdvancedEditorCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                            CommandParameter="{Binding}"
                                                            Style="{StaticResource WaypointGridActionButtonStyle}"
                                                            ToolTip="扩展参数">
                                                        <ui:SymbolIcon FontSize="14"
                                                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                                       Symbol="Settings24" />
                                                    </Button>
                                                    <Button Margin="1,0,0,0"
                                                            Command="{Binding DataContext.MoveRecordedWaypointUpCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                            CommandParameter="{Binding}"
                                                            Style="{StaticResource WaypointGridActionButtonStyle}"
                                                            ToolTip="上移">
                                                        <ui:SymbolIcon FontSize="14"
                                                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                                       Symbol="ArrowUp24" />
                                                    </Button>
                                                    <Button Margin="1,0,0,0"
                                                            Command="{Binding DataContext.MoveRecordedWaypointDownCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                            CommandParameter="{Binding}"
                                                            Style="{StaticResource WaypointGridActionButtonStyle}"
                                                            ToolTip="下移">
                                                        <ui:SymbolIcon FontSize="14"
                                                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                                       Symbol="ArrowDown24" />
                                                    </Button>
                                                    <Button Margin="1,0,0,0"
                                                            Command="{Binding DataContext.CopyRecordedWaypointCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                            CommandParameter="{Binding}"
                                                            Style="{StaticResource WaypointGridActionButtonStyle}"
                                                            ToolTip="复制">
                                                        <ui:SymbolIcon FontSize="14"
                                                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                                       Symbol="Copy24" />
                                                    </Button>
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>

                            <Border Grid.Row="1"
                                    Margin="0,8,0,0"
                                    Padding="12"
                                    Background="{StaticResource MapEditorCardBrush}"
                                    BorderBrush="{StaticResource MapEditorStrokeBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6">
                                <Grid>
                                    <Grid Visibility="{Binding SelectedWaypointEmptyVisibility}">
                                        <TextBlock HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Style="{StaticResource CaptionTextStyle}"
                                                   Text="选择路线点后在这里编辑坐标、类型、移动方式和动作参数。" />
                                    </Grid>

                                    <Grid Visibility="{Binding SelectedWaypointEditorVisibility}">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Style="{StaticResource SectionTitleStyle}"
                                                       Text="{Binding SelectedWaypointEditorTitle}" />
                                        </StackPanel>

                                        <Grid Grid.Row="1"
                                              Margin="0,12,0,0"
                                              DataContext="{Binding SelectedRecordedWaypoint}">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="38" />
                                                <RowDefinition Height="42" />
                                                <RowDefinition Height="42" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="70" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="12" />
                                                <ColumnDefinition Width="78" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Style="{StaticResource CaptionTextStyle}" Text="X 坐标" />
                                            <ui:TextBox Grid.Column="1"
                                                        MinWidth="160"
                                                        Style="{StaticResource FormTextBoxStyle}"
                                                        Text="{Binding XText, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                                            <TextBlock Grid.Column="3"
                                                       Style="{StaticResource CaptionTextStyle}"
                                                       Text="Y 坐标" />
                                            <ui:TextBox Grid.Column="4"
                                                        MinWidth="160"
                                                        Style="{StaticResource FormTextBoxStyle}"
                                                        Text="{Binding YText, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />

                                            <TextBlock Grid.Row="1"
                                                       Style="{StaticResource CaptionTextStyle}"
                                                       Text="点位类型" />
                                            <ComboBox Grid.Row="1"
                                                      Grid.Column="1"
                                                      MinWidth="160"
                                                      Height="34"
                                                      ItemTemplate="{StaticResource MapEditorOptionTemplate}"
                                                      ItemContainerStyle="{StaticResource MapEditorComboBoxItemStyle}"
                                                      ItemsSource="{Binding DataContext.WaypointTypeOptions, RelativeSource={RelativeSource AncestorType=Border}}"
                                                      SelectedValue="{Binding Type, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                      SelectedValuePath="Code"
                                                      Style="{StaticResource MapEditorComboBoxStyle}" />
                                            <TextBlock Grid.Row="1"
                                                       Grid.Column="3"
                                                       Style="{StaticResource CaptionTextStyle}"
                                                       Text="移动方式" />
                                            <ComboBox Grid.Row="1"
                                                      Grid.Column="4"
                                                      MinWidth="160"
                                                      Height="34"
                                                      ItemTemplate="{StaticResource MapEditorOptionTemplate}"
                                                      ItemContainerStyle="{StaticResource MapEditorComboBoxItemStyle}"
                                                      ItemsSource="{Binding DataContext.MoveModeOptions, RelativeSource={RelativeSource AncestorType=Border}}"
                                                      SelectedValue="{Binding MoveMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                      SelectedValuePath="Code"
                                                      Style="{StaticResource MapEditorComboBoxStyle}" />

                                            <TextBlock Grid.Row="2"
                                                       Style="{StaticResource CaptionTextStyle}"
                                                       Text="动作" />
                                            <Button Grid.Row="2"
                                                    Grid.Column="1"
                                                    Click="WaypointActionSelectorButton_Click"
                                                    Content="{Binding ActionDisplayText}"
                                                    Style="{StaticResource MapEditorSelectorButtonStyle}"
                                                    ToolTip="{Binding ActionParameterHint}" />
                                            <TextBlock Grid.Row="2"
                                                       Grid.Column="3"
                                                       Style="{StaticResource CaptionTextStyle}"
                                                       Text="动作参数" />
                                            <Grid Grid.Row="2"
                                                  Grid.Column="4">
                                                <ui:TextBox PlaceholderText="{Binding ActionParameterHint}"
                                                            Style="{StaticResource FormTextBoxStyle}"
                                                            Text="{Binding ActionParams, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                            Visibility="{Binding GeneralActionParameterVisibility}" />
                                                <ComboBox Height="34"
                                                          ItemTemplate="{StaticResource MapEditorCombatScriptTemplate}"
                                                          ItemContainerStyle="{StaticResource MapEditorComboBoxItemStyle}"
                                                          ItemsSource="{Binding DataContext.CombatScripts, RelativeSource={RelativeSource AncestorType=Border}}"
                                                          SelectedValue="{Binding ActionParams, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                          SelectedValuePath="Value"
                                                          Style="{StaticResource MapEditorComboBoxStyle}"
                                                          Visibility="{Binding CombatScriptParameterVisibility}" />
                                            </Grid>
                                            <TextBlock Grid.Row="3"
                                                       Grid.Column="4"
                                                       Margin="0,1,0,0"
                                                       FontSize="11"
                                                       Foreground="{StaticResource MapEditorTextSecondaryBrush}"
                                                       Text="{Binding ActionParameterHint}"
                                                       TextWrapping="Wrap" />
                                        </Grid>

                                    </Grid>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>

                    <Grid Grid.Row="1"
                          Grid.RowSpan="3"
                          Margin="0,8,0,0"
                          Visibility="{Binding DebugMainVisibility}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Style="{StaticResource PanelCardStyle}">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <ui:SymbolIcon Margin="0,0,8,0"
                                                       VerticalAlignment="Center"
                                                       Foreground="{StaticResource MapEditorAccentBrush}"
                                                       Symbol="ClipboardTask24" />
                                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="当前任务" />
                                    </StackPanel>
                                    <Grid Margin="0,12,0,0">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="32" />
                                            <RowDefinition Height="32" />
                                            <RowDefinition Height="42" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="76" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="44" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Style="{StaticResource CaptionTextStyle}" Text="状态" />
                                        <TextBlock Grid.Column="1"
                                                   Grid.ColumnSpan="2"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource MapEditorWarningBrush}"
                                                   Style="{StaticResource InfoValueTextStyle}"
                                                   Text="{Binding TaskName}"
                                                   TextTrimming="CharacterEllipsis" />

                                        <TextBlock Grid.Row="1"
                                                   Style="{StaticResource CaptionTextStyle}"
                                                   Text="路线" />
                                        <TextBlock Grid.Row="1"
                                                   Grid.Column="1"
                                                   Grid.ColumnSpan="2"
                                                   Style="{StaticResource InfoValueTextStyle}"
                                                   Text="{Binding TaskMetaText}"
                                                   TextTrimming="CharacterEllipsis" />

                                        <TextBlock Grid.Row="2"
                                                   Style="{StaticResource CaptionTextStyle}"
                                                   Text="进度" />
                                        <ProgressBar Grid.Row="2"
                                                     Grid.Column="1"
                                                     Height="8"
                                                     Margin="0,13,10,0"
                                                     Maximum="100"
                                                     Minimum="0"
                                                     Value="{Binding RouteProgressValue}" />
                                        <TextBlock Grid.Row="2"
                                                   Grid.Column="2"
                                                   Margin="0,8,0,0"
                                                   Style="{StaticResource CaptionTextStyle}"
                                                   HorizontalAlignment="Right"
                                                   Text="{Binding RouteProgressText}" />
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2" Style="{StaticResource PanelCardStyle}">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <ui:SymbolIcon Margin="0,0,8,0"
                                                       VerticalAlignment="Center"
                                                       Foreground="{StaticResource MapEditorAccentBrush}"
                                                       Symbol="ArrowTrending24" />
                                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="下一步" />
                                    </StackPanel>
                                    <Grid Margin="0,12,0,0">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="34" />
                                            <RowDefinition Height="34" />
                                            <RowDefinition Height="34" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="78" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Style="{StaticResource CaptionTextStyle}" Text="下一路点" />
                                        <TextBlock Grid.Column="1"
                                                   Style="{StaticResource InfoValueTextStyle}"
                                                   Text="{Binding NextWaypointText}"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Row="1"
                                                   Style="{StaticResource CaptionTextStyle}"
                                                   Text="下一动作" />
                                        <TextBlock Grid.Row="1"
                                                   Grid.Column="1"
                                                   Style="{StaticResource InfoValueTextStyle}"
                                                   Text="{Binding NextWaypointActionText}"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Row="2"
                                                   Style="{StaticResource CaptionTextStyle}"
                                                   Text="动作参数" />
                                        <TextBlock Grid.Row="2"
                                                   Grid.Column="1"
                                                   Style="{StaticResource InfoValueTextStyle}"
                                                   Text="{Binding NextWaypointActionParamsText}"
                                                   TextTrimming="CharacterEllipsis" />
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Grid Grid.Row="1" Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Style="{StaticResource PanelCardStyle}">
                                <StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="移动模式" />
                                        <TextBlock Grid.Column="1"
                                                   Style="{StaticResource CaptionTextStyle}"
                                                   Text="{Binding FollowZoomText}" />
                                    </Grid>
                                    <TextBlock Margin="0,10,0,0"
                                               Style="{StaticResource InfoValueTextStyle}"
                                               Text="{Binding MoveModeSummary}"
                                               TextWrapping="Wrap" />
                                    <Grid Margin="0,12,0,0">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <TextBlock Style="{StaticResource CaptionTextStyle}" Text="跟随缩放" />
                                        <Slider Grid.Row="1"
                                                Margin="0,6,0,0"
                                                IsSnapToTickEnabled="False"
                                                LargeChange="0.5"
                                                Maximum="8"
                                                Minimum="0.2"
                                                SmallChange="0.1"
                                                TickFrequency="0.1"
                                                Value="{Binding FollowZoom, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2" Style="{StaticResource PanelCardStyle}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="目标与规划" />
                                    <ui:Button Grid.Column="1"
                                               Width="32"
                                               Height="28"
                                               Padding="0"
                                               Command="{Binding PlanRouteCommand}"
                                               Icon="{ui:SymbolIcon Play24}"
                                               ToolTip="规划路线" />

                                    <TextBlock Grid.Row="1"
                                               Grid.ColumnSpan="2"
                                               Margin="0,10,0,0"
                                               Style="{StaticResource InfoValueTextStyle}"
                                               Text="{Binding SelectedTargetText}"
                                               TextWrapping="Wrap" />

                                    <Grid Grid.Row="2"
                                          Grid.ColumnSpan="2"
                                          Margin="0,10,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="44" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="44" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Style="{StaticResource CaptionTextStyle}" Text="目标X" />
                                        <ui:TextBox Grid.Column="1"
                                                    Style="{StaticResource FormTextBoxStyle}"
                                                    Text="{Binding TargetImageX, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBlock Grid.Column="3"
                                                   Style="{StaticResource CaptionTextStyle}"
                                                   Text="目标Y" />
                                        <ui:TextBox Grid.Column="4"
                                                    Style="{StaticResource FormTextBoxStyle}"
                                                    Text="{Binding TargetImageY, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </Grid>

                                    <Grid Grid.Row="3"
                                          Grid.ColumnSpan="2"
                                          Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="72" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Style="{StaticResource CaptionTextStyle}" Text="终点模式" />
                                        <ComboBox Grid.Column="1"
                                                  ItemTemplate="{StaticResource MapEditorOptionTemplate}"
                                                  ItemContainerStyle="{StaticResource MapEditorComboBoxItemStyle}"
                                                  ItemsSource="{Binding TargetMoveModeOptions}"
                                                  SelectedValue="{Binding TargetMoveMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  SelectedValuePath="Code"
                                                  Style="{StaticResource MapEditorComboBoxStyle}" />
                                    </Grid>

                                    <Grid Grid.Row="4"
                                          Grid.ColumnSpan="2"
                                          Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="72" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Style="{StaticResource CaptionTextStyle}" Text="目标动作" />
                                        <Button Grid.Column="1"
                                                Click="TargetActionSelectorButton_Click"
                                                Content="{Binding TargetActionDisplayText}"
                                                Style="{StaticResource MapEditorSelectorButtonStyle}"
                                                ToolTip="{Binding TargetActionParameterHint}" />
                                    </Grid>
                                </Grid>
                            </Border>
                        </Grid>

                        <Border Grid.Row="2"
                                Margin="0,8,0,0"
                                Style="{StaticResource PanelCardStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="调试详情" />
                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <ui:Button Width="32"
                                                   Height="32"
                                                   Padding="0"
                                                   Command="{Binding RefreshCurrentViewCommand}"
                                                   Icon="{ui:SymbolIcon Location24}"
                                                   ToolTip="定位当前" />
                                        <ui:Button Width="32"
                                                   Height="32"
                                                   Margin="8,0,0,0"
                                                   Padding="0"
                                                   Command="{Binding ClearPathingCommand}"
                                                   Icon="{ui:SymbolIcon Dismiss24}"
                                                   ToolTip="清空路径" />
                                        <ui:Button Width="32"
                                                   Height="32"
                                                   Margin="8,0,0,0"
                                                   Padding="0"
                                                   Command="{Binding RefreshRouteDiagnosticsLiteCommand}"
                                                   Icon="{ui:SymbolIcon ArrowClockwise24}"
                                                   ToolTip="刷新路网数据" />
                                        <ui:Button Width="32"
                                                   Height="32"
                                                   Margin="8,0,0,0"
                                                   Padding="0"
                                                   Command="{Binding RefreshRouteGraphDiagnosticsCommand}"
                                                   Icon="{ui:SymbolIcon Search24}"
                                                   ToolTip="查询附近节点和边" />
                                        <ui:Button Width="32"
                                                   Height="32"
                                                   Margin="8,0,0,0"
                                                   Padding="0"
                                                   Command="{Binding RebuildRouteGraphCommand}"
                                                   Icon="{ui:SymbolIcon Settings24}"
                                                   ToolTip="重建路网" />
                                        <ui:Button Width="32"
                                                   Height="32"
                                                   Margin="8,0,0,0"
                                                   Padding="0"
                                                   Command="{Binding OpenRoutesFolderCommand}"
                                                   Icon="{ui:SymbolIcon FolderOpen24}"
                                                   ToolTip="打开路网目录" />
                                    </StackPanel>
                                </Grid>
                                <Grid Grid.Row="1" Margin="0,12,0,0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="30" />
                                        <RowDefinition Height="30" />
                                        <RowDefinition Height="30" />
                                        <RowDefinition Height="30" />
                                        <RowDefinition Height="30" />
                                        <RowDefinition Height="30" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="88" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="28" />
                                        <ColumnDefinition Width="88" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Style="{StaticResource CaptionTextStyle}" Text="当前位置" />
                                    <TextBlock Grid.Column="1"
                                               Style="{StaticResource DebugValueTextStyle}"
                                               Text="{Binding CurrentPositionDetailText}" />
                                    <TextBlock Grid.Column="3"
                                               Style="{StaticResource CaptionTextStyle}"
                                               Text="当前路线" />
                                    <TextBlock Grid.Column="4"
                                               Style="{StaticResource DebugValueTextStyle}"
                                               Text="{Binding TaskName}" />

                                    <TextBlock Grid.Row="1"
                                               Style="{StaticResource CaptionTextStyle}"
                                               Text="目标点" />
                                    <TextBlock Grid.Row="1"
                                               Grid.Column="1"
                                               Style="{StaticResource DebugValueTextStyle}"
                                               Text="{Binding SelectedTargetDetailText}" />
                                    <TextBlock Grid.Row="1"
                                               Grid.Column="3"
                                               Style="{StaticResource CaptionTextStyle}"
                                               Text="路线来源" />
                                    <TextBlock Grid.Row="1"
                                               Grid.Column="4"
                                               Style="{StaticResource DebugValueTextStyle}"
                                               Text="{Binding TaskMetaText}" />

                                    <TextBlock Grid.Row="2"
                                               Style="{StaticResource CaptionTextStyle}"
                                               Text="视野" />
                                    <TextBlock Grid.Row="2"
                                               Grid.Column="1"
                                               Style="{StaticResource DebugValueTextStyle}"
                                               Text="{Binding ClipRectDetailText}" />
                                    <TextBlock Grid.Row="2"
                                               Grid.Column="3"
                                               Style="{StaticResource CaptionTextStyle}"
                                               Text="下一路点" />
                                    <TextBlock Grid.Row="2"
                                               Grid.Column="4"
                                               Style="{StaticResource DebugValueTextStyle}"
                                               Text="{Binding NextWaypointText}" />

                                    <TextBlock Grid.Row="3"
                                               Style="{StaticResource CaptionTextStyle}"
                                               Text="刷新时间" />
                                    <TextBlock Grid.Row="3"
                                               Grid.Column="1"
                                               Style="{StaticResource DebugValueTextStyle}"
                                               Text="{Binding LastRefreshDetailText}" />
                                    <TextBlock Grid.Row="3"
                                               Grid.Column="3"
                                               Style="{StaticResource CaptionTextStyle}"
                                               Text="下一动作" />
                                    <TextBlock Grid.Row="3"
                                               Grid.Column="4"
                                               Style="{StaticResource DebugValueTextStyle}"
                                               Text="{Binding NextWaypointActionText}" />

                                    <TextBlock Grid.Row="4"
                                               Style="{StaticResource CaptionTextStyle}"
                                               Text="地图" />
                                    <TextBlock Grid.Row="4"
                                               Grid.Column="1"
                                               Style="{StaticResource DebugValueTextStyle}"
                                               Text="{Binding MapDisplayName}" />
                                    <TextBlock Grid.Row="4"
                                               Grid.Column="3"
                                               Style="{StaticResource CaptionTextStyle}"
                                               Text="动作参数" />
                                    <TextBlock Grid.Row="4"
                                               Grid.Column="4"
                                               Style="{StaticResource DebugValueTextStyle}"
                                               Text="{Binding NextWaypointActionParamsText}" />

                                    <TextBlock Grid.Row="5"
                                               Style="{StaticResource CaptionTextStyle}"
                                               Text="距离" />
                                    <TextBlock Grid.Row="5"
                                               Grid.Column="1"
                                               Style="{StaticResource DebugValueTextStyle}"
                                               Text="{Binding RouteDistanceDetailText}" />
                                    <TextBlock Grid.Row="5"
                                               Grid.Column="3"
                                               Style="{StaticResource CaptionTextStyle}"
                                               Text="点位进度" />
                                    <TextBlock Grid.Row="5"
                                               Grid.Column="4"
                                               Style="{StaticResource DebugValueTextStyle}"
                                               Text="{Binding RouteProgressPointText}" />
                                </Grid>

                                <Grid Grid.Row="2" Margin="0,12,0,8">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="38" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="88" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="28" />
                                        <ColumnDefinition Width="88" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Style="{StaticResource CaptionTextStyle}" Text="规划起点 X" />
                                    <ui:TextBox Grid.Column="1"
                                                Style="{StaticResource FormTextBoxStyle}"
                                                Text="{Binding CurrentImageX, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Grid.Column="3"
                                               Style="{StaticResource CaptionTextStyle}"
                                               Text="规划起点 Y" />
                                    <ui:TextBox Grid.Column="4"
                                                Style="{StaticResource FormTextBoxStyle}"
                                                Text="{Binding CurrentImageY, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                    <WrapPanel Grid.Row="1"
                                               Grid.ColumnSpan="5"
                                               Margin="0,8,0,0">
                                        <CheckBox Margin="0,0,16,0"
                                                  Content="跟随当前坐标"
                                                  Foreground="{StaticResource MapEditorTextPrimaryBrush}"
                                                  IsChecked="{Binding FollowRoutePlanningCurrentPosition, Mode=TwoWay}" />
                                        <CheckBox Margin="0,0,16,0"
                                                  Content="允许传送"
                                                  Foreground="{StaticResource MapEditorTextPrimaryBrush}"
                                                  IsChecked="{Binding AllowTeleport, Mode=TwoWay}" />
                                        <CheckBox Margin="0,0,16,0"
                                                  Content="未知起点连接"
                                                  Foreground="{StaticResource MapEditorTextPrimaryBrush}"
                                                  IsChecked="{Binding AllowUnknownStartConnector, Mode=TwoWay}" />
                                        <CheckBox Margin="0,0,16,0"
                                                  Content="未知目标连接"
                                                  Foreground="{StaticResource MapEditorTextPrimaryBrush}"
                                                  IsChecked="{Binding AllowUnknownTargetConnector, Mode=TwoWay}" />
                                        <CheckBox Margin="0,0,16,0"
                                                  Content="允许禁用边"
                                                  Foreground="{StaticResource MapEditorTextPrimaryBrush}"
                                                  IsChecked="{Binding AllowDisabledEdges, Mode=TwoWay}" />
                                    </WrapPanel>

                                    <StackPanel Grid.Row="2"
                                                Grid.ColumnSpan="5"
                                                Margin="0,8,0,0">
                                        <TextBlock FontWeight="SemiBold"
                                                   Text="{Binding PlanSummary}"
                                                   TextWrapping="Wrap" />
                                        <TextBlock Margin="0,4,0,0"
                                                   Style="{StaticResource CaptionTextStyle}"
                                                   Text="{Binding GraphStatus}"
                                                   TextWrapping="Wrap" />
                                        <TextBlock Margin="0,4,0,0"
                                                   Style="{StaticResource CaptionTextStyle}"
                                                   Text="{Binding TargetPickSummary}"
                                                   TextWrapping="Wrap" />
                                        <TextBlock Margin="0,4,0,0"
                                                   Style="{StaticResource CaptionTextStyle}"
                                                   Text="{Binding GraphSummary}"
                                                   TextWrapping="Wrap" />
                                        <TextBlock Margin="0,4,0,0"
                                                   Style="{StaticResource CaptionTextStyle}"
                                                   Text="{Binding HealthSummary}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </Grid>

                                <TabControl Grid.Row="3" MinHeight="140">
                                    <TabItem Header="规划边">
                                        <DataGrid AutoGenerateColumns="False"
                                                  CanUserAddRows="False"
                                                  CanUserDeleteRows="False"
                                                  HeadersVisibility="Column"
                                                  IsReadOnly="True"
                                                  ItemsSource="{Binding PlannedEdges}"
                                                  ScrollViewer.HorizontalScrollBarVisibility="Auto">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Width="42" Binding="{Binding Index}" Header="#" />
                                                <DataGridTextColumn Width="104" Binding="{Binding FromNodeId}" Header="From" />
                                                <DataGridTextColumn Width="104" Binding="{Binding ToNodeId}" Header="To" />
                                                <DataGridTextColumn Width="70" Binding="{Binding Cost, StringFormat=F2}" Header="Cost" />
                                                <DataGridTextColumn Width="82" Binding="{Binding MoveMode}" Header="Move" />
                                                <DataGridTextColumn Width="112" Binding="{Binding Action}" Header="Action" />
                                                <DataGridTextColumn Width="88" Binding="{Binding HealthStatus}" Header="Health" />
                                                <DataGridCheckBoxColumn Width="74" Binding="{Binding IsSyntheticReverse}" Header="Reverse" />
                                                <DataGridCheckBoxColumn Width="68" Binding="{Binding IsBidirectionalCandidate}" Header="BiDir" />
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </TabItem>
                                    <TabItem Header="附近节点">
                                        <DataGrid AutoGenerateColumns="False"
                                                  CanUserAddRows="False"
                                                  CanUserDeleteRows="False"
                                                  HeadersVisibility="Column"
                                                  IsReadOnly="True"
                                                  ItemsSource="{Binding NearbyNodes}"
                                                  ScrollViewer.HorizontalScrollBarVisibility="Auto">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Width="128" Binding="{Binding NodeId}" Header="Node" />
                                                <DataGridTextColumn Width="82" Binding="{Binding X, StringFormat=F1}" Header="X" />
                                                <DataGridTextColumn Width="82" Binding="{Binding Y, StringFormat=F1}" Header="Y" />
                                                <DataGridTextColumn Width="86" Binding="{Binding Distance, StringFormat=F1}" Header="Distance" />
                                                <DataGridTextColumn Width="74" Binding="{Binding Anchors}" Header="Anchors" />
                                                <DataGridTextColumn Width="86" Binding="{Binding Resources}" Header="Resources" />
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </TabItem>
                                    <TabItem Header="附近边">
                                        <DataGrid AutoGenerateColumns="False"
                                                  CanUserAddRows="False"
                                                  CanUserDeleteRows="False"
                                                  HeadersVisibility="Column"
                                                  IsReadOnly="True"
                                                  ItemsSource="{Binding NearbyEdges}"
                                                  ScrollViewer.HorizontalScrollBarVisibility="Auto">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Width="128" Binding="{Binding EdgeId}" Header="Edge" />
                                                <DataGridTextColumn Width="86" Binding="{Binding Distance, StringFormat=F1}" Header="Distance" />
                                                <DataGridTextColumn Width="70" Binding="{Binding Cost, StringFormat=F2}" Header="Cost" />
                                                <DataGridTextColumn Width="82" Binding="{Binding MoveMode}" Header="Move" />
                                                <DataGridTextColumn Width="112" Binding="{Binding Action}" Header="Action" />
                                                <DataGridTextColumn Width="88" Binding="{Binding HealthStatus}" Header="Health" />
                                                <DataGridCheckBoxColumn Width="74" Binding="{Binding Reverse}" Header="Reverse" />
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </TabItem>
                                    <TabItem Header="健康记录">
                                        <DataGrid AutoGenerateColumns="False"
                                                  CanUserAddRows="False"
                                                  CanUserDeleteRows="False"
                                                  HeadersVisibility="Column"
                                                  IsReadOnly="True"
                                                  ItemsSource="{Binding HealthRows}"
                                                  ScrollViewer.HorizontalScrollBarVisibility="Auto">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Width="128" Binding="{Binding SegmentId}" Header="Segment" />
                                                <DataGridTextColumn Width="82" Binding="{Binding Status}" Header="Status" />
                                                <DataGridTextColumn Width="68" Binding="{Binding Success}" Header="Success" />
                                                <DataGridTextColumn Width="68" Binding="{Binding Failure}" Header="Failure" />
                                                <DataGridTextColumn Width="66" Binding="{Binding Rate, StringFormat=P0}" Header="Rate" />
                                                <DataGridTextColumn Width="82" Binding="{Binding MoveMode}" Header="Move" />
                                                <DataGridTextColumn Width="112" Binding="{Binding Action}" Header="Action" />
                                                <DataGridTextColumn Width="190" Binding="{Binding LastFailure}" Header="LastFailure" />
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </TabItem>
                                </TabControl>
                            </Grid>
                        </Border>
                    </Grid>

                    <Border Grid.Row="2"
                            Margin="0,8,0,0"
                            Padding="10"
                            Background="{StaticResource MapEditorCardBrush}"
                            BorderBrush="{StaticResource MapEditorStrokeBrush}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Visibility="{Binding RecorderJsonEditorVisibility}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="JSON 编辑" />
                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <ui:Button Height="32"
                                               Command="{Binding RefreshJsonFromUiCommand}"
                                               Content="重新生成"
                                               Icon="{ui:SymbolIcon ArrowClockwise24}" />
                                    <ui:Button Height="32"
                                               Margin="8,0,0,0"
                                               Command="{Binding ApplyJsonEditsCommand}"
                                               Content="应用"
                                               Icon="{ui:SymbolIcon Save24}" />
                                    <ui:Button Height="32"
                                               Margin="8,0,0,0"
                                               Command="{Binding SwitchToRecorderUiEditorCommand}"
                                               Content="表单编辑"
                                               Icon="{ui:SymbolIcon Edit24}" />
                                </StackPanel>
                            </Grid>
                            <codeEditor:JsonCodeBox Grid.Row="1"
                                                    Margin="0,10,0,0"
                                                    Padding="6"
                                                    Background="#FF111923"
                                                    BorderBrush="{StaticResource MapEditorStrokeBrush}"
                                                    BorderThickness="1"
                                                    Code="{Binding DebugJsonText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                    FontFamily="Consolas"
                                                    FontSize="12"
                                                    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                    HorizontalScrollBarVisibility="Auto"
                                                    IsReadOnly="False"
                                                    LineWrap="False"
                                                    VerticalScrollBarVisibility="Auto" />
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</ui:FluentWindow>
