                                                   Height="32"
                                                   Command="{Binding CloseActionUsageEditorCommand}"
                                                   Content="完成"
                                                   Icon="{ui:SymbolIcon Checkmark24}" />
                                    </StackPanel>
                                </Grid>
                            </Border>
