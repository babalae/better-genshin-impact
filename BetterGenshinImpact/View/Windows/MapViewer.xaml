<ui:FluentWindow x:Class="BetterGenshinImpact.View.Windows.MapViewer"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:behavior="clr-namespace:BetterGenshinImpact.View.Behavior"
                 xmlns:codeEditor="clr-namespace:BetterGenshinImpact.View.Controls.CodeEditor"
                 xmlns:controls="clr-namespace:BetterGenshinImpact.View.Controls"
                 xmlns:windows="clr-namespace:BetterGenshinImpact.ViewModel.Windows"
                 Title="路线录制 - 调试工具"
                 Width="1440"
                 Height="820"
                 MinWidth="1180"
                 MinHeight="680"
                 d:DataContext="{d:DesignInstance Type=windows:MapViewerViewModel}"
                 ui:Design.Background="{DynamicResource ApplicationBackgroundBrush}"
                 ui:Design.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                 ExtendsContentIntoTitleBar="True"
                 behavior:AutoTranslateInterceptor.EnableAutoTranslate="True"
                 FontFamily="{DynamicResource TextThemeFontFamily}"
                 ResizeMode="CanResize"
                 Topmost="{Binding IsTopmost}"
                 WindowBackdropType="Mica"
                 WindowStartupLocation="CenterScreen"
                 WindowStyle="SingleBorderWindow"
                 mc:Ignorable="d">
    <ui:FluentWindow.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <SolidColorBrush x:Key="MapEditorPanelBrush" Color="#E812171B" />
        <SolidColorBrush x:Key="MapEditorCardBrush" Color="#D8172026" />
        <SolidColorBrush x:Key="MapEditorInsetBrush" Color="#99111822" />
        <SolidColorBrush x:Key="MapEditorStrokeBrush" Color="#33485761" />
        <SolidColorBrush x:Key="MapEditorGridLineBrush" Color="#18252D" />
        <SolidColorBrush x:Key="MapEditorAccentBrush" Color="#23C8D2" />
        <SolidColorBrush x:Key="MapEditorWarningBrush" Color="#F1B44C" />
        <SolidColorBrush x:Key="MapEditorDangerBrush" Color="#EB5545" />
        <SolidColorBrush x:Key="MapEditorTextPrimaryBrush" Color="#F3F7FA" />
        <SolidColorBrush x:Key="MapEditorTextSecondaryBrush" Color="#C7D2DA" />

        <Style x:Key="PanelCardStyle" TargetType="Border">
            <Setter Property="Padding" Value="12" />
            <Setter Property="Background" Value="{StaticResource MapEditorCardBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource MapEditorStrokeBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
        </Style>

        <Style x:Key="OverlayCardStyle" TargetType="Border">
            <Setter Property="Padding" Value="12,9" />
            <Setter Property="Background" Value="#D9111820" />
            <Setter Property="BorderBrush" Value="#4039DCEB" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource MapEditorTextPrimaryBrush}" />
        </Style>

        <Style x:Key="CaptionTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MapEditorTextSecondaryBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="DebugValueTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MapEditorTextPrimaryBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style x:Key="InfoValueTextStyle" TargetType="TextBlock" BasedOn="{StaticResource DebugValueTextStyle}">
            <Setter Property="HorizontalAlignment" Value="Left" />
        </Style>

        <Style x:Key="FormTextBoxStyle" TargetType="ui:TextBox">
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="8,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Background" Value="{StaticResource MapEditorInsetBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource MapEditorStrokeBrush}" />
            <Setter Property="Foreground" Value="{StaticResource MapEditorTextPrimaryBrush}" />
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MapEditorTextPrimaryBrush}" />
        </Style>

        <DataTemplate x:Key="MapEditorOptionTemplate">
            <TextBlock Foreground="{StaticResource MapEditorTextPrimaryBrush}"
                       Text="{Binding DisplayName}" />
        </DataTemplate>

        <DataTemplate x:Key="WaypointGridOptionTemplate">
            <TextBlock HorizontalAlignment="Center"
                       Foreground="{StaticResource MapEditorTextPrimaryBrush}"
                       Text="{Binding DisplayName}"
                       TextAlignment="Center"
                       TextTrimming="CharacterEllipsis" />
        </DataTemplate>

        <DataTemplate x:Key="MapEditorCombatScriptTemplate">
            <TextBlock Foreground="{StaticResource MapEditorTextPrimaryBrush}"
                       Text="{Binding Value}"
                       TextTrimming="CharacterEllipsis" />
        </DataTemplate>

        <Style x:Key="MapEditorComboBoxItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{StaticResource MapEditorTextPrimaryBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="ToolTip" Value="{Binding ParameterHint}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Root"
                                Margin="4,1"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#26313B" />
                            </Trigger>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#26313B" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#B0147884" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MapEditorComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="8,0" />
            <Setter Property="MinWidth" Value="80" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="ScrollViewer.CanContentScroll" Value="True" />
            <Setter Property="MaxDropDownHeight" Value="260" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{StaticResource MapEditorTextPrimaryBrush}" />
            <Setter Property="Background" Value="{StaticResource MapEditorInsetBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource MapEditorStrokeBrush}" />
            <Setter Property="ItemContainerStyle" Value="{StaticResource MapEditorComboBoxItemStyle}" />
            <EventSetter Event="PreviewMouseLeftButtonDown" Handler="MapEditorComboBox_PreviewMouseLeftButtonDown" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="Root"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="4">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="30" />
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter x:Name="ContentSite"
                                                      Margin="{TemplateBinding Padding}"
                                                      HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      IsHitTestVisible="False"
                                                      RecognizesAccessKey="True" />
                                    <ui:SymbolIcon Grid.Column="1"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   FontSize="14"
                                                   Foreground="{StaticResource MapEditorTextSecondaryBrush}"
                                                   Symbol="ChevronDown16" />
                                </Grid>
                            </Border>
                            <Popup x:Name="PART_Popup"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                   Placement="Bottom">
                                <Border x:Name="DropDownBorder"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                        Margin="0,4,0,0"
                                        Padding="2"
                                        Background="#FF1A2025"
                                        BorderBrush="{StaticResource MapEditorStrokeBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6">
                                    <ScrollViewer CanContentScroll="True"
                                                  HorizontalScrollBarVisibility="Disabled"
                                                  VerticalScrollBarVisibility="Auto">
                                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="#6639DCEB" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource MapEditorAccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource MapEditorAccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Background" Value="#66111822" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource MapEditorStrokeBrush}" />
                                <Setter Property="Foreground" Value="#88C7D2DA" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="WaypointGridComboBoxStyle"
               BasedOn="{StaticResource MapEditorComboBoxStyle}"
               TargetType="ComboBox">
            <Setter Property="Height" Value="28" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Margin" Value="2,0" />
            <Setter Property="Padding" Value="5,0" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="Root"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="4">
                                <ContentPresenter x:Name="ContentSite"
                                                  Margin="{TemplateBinding Padding}"
                                                  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                                  Content="{TemplateBinding SelectionBoxItem}"
                                                  ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                  IsHitTestVisible="False"
                                                  RecognizesAccessKey="True" />
                            </Border>
                            <Popup x:Name="PART_Popup"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                   Placement="Bottom">
                                <Border x:Name="DropDownBorder"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                        Margin="0,4,0,0"
                                        Padding="2"
                                        Background="#FF1A2025"
                                        BorderBrush="{StaticResource MapEditorStrokeBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6">
                                    <ScrollViewer CanContentScroll="True"
                                                  HorizontalScrollBarVisibility="Disabled"
                                                  VerticalScrollBarVisibility="Auto">
                                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="#6639DCEB" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource MapEditorAccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource MapEditorAccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Background" Value="#66111822" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource MapEditorStrokeBrush}" />
                                <Setter Property="Foreground" Value="#88C7D2DA" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Foreground" Value="{StaticResource MapEditorTextPrimaryBrush}" />
            <Setter Property="RowBackground" Value="#00172026" />
            <Setter Property="AlternatingRowBackground" Value="#141F2A31" />
            <Setter Property="GridLinesVisibility" Value="None" />
            <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource MapEditorGridLineBrush}" />
            <Setter Property="VerticalGridLinesBrush" Value="{StaticResource MapEditorGridLineBrush}" />
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Foreground" Value="{StaticResource MapEditorTextPrimaryBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="BorderBrush" Value="Transparent" />
                    <Setter Property="Foreground" Value="{StaticResource MapEditorAccentBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Foreground" Value="{StaticResource MapEditorTextPrimaryBrush}" />
            <Setter Property="Background" Value="#FF172026" />
            <Setter Property="BorderBrush" Value="{StaticResource MapEditorGridLineBrush}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="8,0" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="MapEditorListBoxStyle" TargetType="ListBox">
            <Setter Property="Background" Value="{StaticResource MapEditorInsetBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource MapEditorStrokeBrush}" />
            <Setter Property="Foreground" Value="{StaticResource MapEditorTextPrimaryBrush}" />
            <Setter Property="Padding" Value="4" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
        </Style>

        <Style x:Key="MapEditorListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="Foreground" Value="{StaticResource MapEditorTextPrimaryBrush}" />
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Root"
                                Margin="0,1"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#26313B" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#B0147884" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#6639DCEB" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RecordedRouteListBoxItemStyle"
               BasedOn="{StaticResource MapEditorListBoxItemStyle}"
               TargetType="ListBoxItem">
            <Setter Property="Tag" Value="{Binding DataContext, RelativeSource={RelativeSource AncestorType=ListBox}}" />
            <Setter Property="ContextMenu">
                <Setter.Value>
                    <ContextMenu>
                        <ui:MenuItem Command="{Binding PlacementTarget.Tag.NewRecordingCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                     Header="新建路线"
                                     Icon="{ui:SymbolIcon Add24}" />
                        <Separator />
                        <ui:MenuItem Command="{Binding PlacementTarget.Tag.OpenRecordedRoutePropertiesCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                     CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                     Header="属性"
                                     Icon="{ui:SymbolIcon Settings24}" />
                        <ui:MenuItem Command="{Binding PlacementTarget.Tag.RenameRecordedRouteCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                     CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                     Header="重命名"
                                     Icon="{ui:SymbolIcon Edit24}" />
                        <ui:MenuItem Command="{Binding PlacementTarget.Tag.CopyRecordedRouteCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                     CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                     Header="复制"
                                     Icon="{ui:SymbolIcon Copy24}" />
                        <Separator Visibility="{Binding PlacementTarget.Tag.RecordedRouteSelectionActionSeparatorVisibility, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                        <ui:MenuItem Command="{Binding PlacementTarget.Tag.SwitchToRecorderJsonEditorCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                     Header="JSON 编辑"
                                     Icon="{ui:SymbolIcon ClipboardTask24}"
                                     Visibility="{Binding PlacementTarget.Tag.SingleRecordedRouteSelectionVisibility, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                        <ui:MenuItem Command="{Binding PlacementTarget.Tag.SplitRecordingByTeleportCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                     Header="按传送点拆分"
                                     Icon="{ui:SymbolIcon BranchFork24}"
                                     Visibility="{Binding PlacementTarget.Tag.SingleRecordedRouteSelectionVisibility, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                        <ui:MenuItem Command="{Binding PlacementTarget.Tag.MergeRecordedRoutesCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                     Header="合并路线"
                                     Icon="{ui:SymbolIcon Archive24}"
                                     Visibility="{Binding PlacementTarget.Tag.MultipleRecordedRouteSelectionVisibility, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                        <Separator />
                        <ui:MenuItem Command="{Binding PlacementTarget.Tag.DeleteSelectedRecordedRouteCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                     CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                     Foreground="{StaticResource MapEditorDangerBrush}"
                                     Header="删除"
                                     Icon="{ui:SymbolIcon Delete24}" />
                    </ContextMenu>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="RecordedRouteListItemTemplate">
            <Grid MinHeight="34">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Ellipse Width="7"
                         Height="7"
                         Margin="0,0,8,0"
                         VerticalAlignment="Center"
                         Fill="{StaticResource MapEditorTextPrimaryBrush}"
                         Visibility="{Binding UnsavedIndicatorVisibility}" />
                <Grid Grid.Column="1"
                      VerticalAlignment="Center">
                    <TextBlock VerticalAlignment="Center"
                               FontWeight="SemiBold"
                               Text="{Binding Name}"
                               TextTrimming="CharacterEllipsis"
                               Visibility="{Binding RenameDisplayVisibility}" />
                    <ui:TextBox Height="28"
                                Padding="8,0"
                                Loaded="RecordedRouteRenameTextBox_Loaded"
                                LostFocus="RecordedRouteRenameTextBox_LostFocus"
                                PreviewKeyDown="RecordedRouteRenameTextBox_PreviewKeyDown"
                                Style="{StaticResource FormTextBoxStyle}"
                                Text="{Binding EditingName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                Visibility="{Binding RenameEditorVisibility}" />
                </Grid>
                <TextBlock Grid.Column="2"
                           Margin="12,0,0,0"
                           VerticalAlignment="Center"
                           Style="{StaticResource CaptionTextStyle}"
                           Text="{Binding PointCountText}" />
            </Grid>
        </DataTemplate>

        <Style x:Key="WaypointGridTextStyle" TargetType="TextBlock">
            <Setter Property="Padding" Value="8,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{StaticResource MapEditorTextPrimaryBrush}" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="TextAlignment" Value="Center" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource MapEditorAccentBrush}" />
                    <Setter Property="FontWeight" Value="SemiBold" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="WaypointCoordinateTextStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{StaticResource MapEditorTextPrimaryBrush}" />
            <Setter Property="FontFamily" Value="Consolas" />
            <Setter Property="TextAlignment" Value="Right" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource MapEditorAccentBrush}" />
                    <Setter Property="FontWeight" Value="SemiBold" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="WaypointCoordinateSeparatorStyle" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{StaticResource MapEditorTextPrimaryBrush}" />
            <Setter Property="FontFamily" Value="Consolas" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource MapEditorAccentBrush}" />
                    <Setter Property="FontWeight" Value="SemiBold" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="MapEditorUiButtonBaseStyle" TargetType="ui:Button">
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="Background" Value="#242A30" />
            <Setter Property="BorderBrush" Value="{StaticResource MapEditorStrokeBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Foreground" Value="{StaticResource MapEditorTextPrimaryBrush}" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ui:Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{TemplateBinding CornerRadius}">
                            <Grid x:Name="ContentPanel"
                                  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <ContentPresenter x:Name="IconPresenter"
                                                  Margin="0,0,7,0"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Content="{TemplateBinding Icon}"
                                                  TextElement.Foreground="{TemplateBinding Foreground}" />
                                <ContentPresenter x:Name="ContentPresenter"
                                                  Grid.Column="1"
                                                  HorizontalAlignment="Stretch"
                                                  VerticalAlignment="Center"
                                                  Content="{TemplateBinding Content}"
                                                  ContentStringFormat="{TemplateBinding ContentStringFormat}"
                                                  ContentTemplate="{TemplateBinding ContentTemplate}"
                                                  RecognizesAccessKey="True"
                                                  TextElement.Foreground="{TemplateBinding Foreground}" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Appearance" Value="Transparent">
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="BorderBrush" Value="Transparent" />
                            </Trigger>
                            <Trigger Property="Icon" Value="{x:Null}">
                                <Setter TargetName="ContentPresenter" Property="Grid.Column" Value="0" />
                                <Setter TargetName="ContentPresenter" Property="Grid.ColumnSpan" Value="2" />
                                <Setter TargetName="IconPresenter" Property="Margin" Value="0" />
                                <Setter TargetName="IconPresenter" Property="Visibility" Value="Collapsed" />
                            </Trigger>
                            <Trigger Property="Content" Value="{x:Null}">
                                <Setter TargetName="IconPresenter" Property="Grid.ColumnSpan" Value="2" />
                                <Setter TargetName="IconPresenter" Property="Margin" Value="0" />
                                <Setter TargetName="ContentPresenter" Property="Visibility" Value="Collapsed" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#26313B" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#6639DCEB" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource MapEditorAccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#B0147884" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource MapEditorAccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style BasedOn="{StaticResource MapEditorUiButtonBaseStyle}" TargetType="ui:Button" />

        <Style x:Key="ToolbarButtonStyle"
               BasedOn="{StaticResource MapEditorUiButtonBaseStyle}"
               TargetType="ui:Button">
            <Setter Property="Width" Value="46" />
            <Setter Property="Height" Value="42" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Appearance" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
        </Style>

        <Style x:Key="MapEditorMenuButtonStyle" TargetType="ui:DropDownButton">
            <Setter Property="Height" Value="30" />
            <Setter Property="MinWidth" Value="64" />
            <Setter Property="Padding" Value="8,0" />
            <Setter Property="Appearance" Value="Transparent" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource MapEditorTextSecondaryBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="MapToolButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="42" />
            <Setter Property="Height" Value="36" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Foreground" Value="#D7E4EA" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="WaypointGridActionButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="20" />
            <Setter Property="Height" Value="26" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource MapEditorTextPrimaryBrush}" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#26313B" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#B0147884" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="WaypointGridSelectorButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="28" />
            <Setter Property="Padding" Value="6,0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{StaticResource MapEditorTextPrimaryBrush}" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#26313B" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#6639DCEB" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#B0147884" />
                            </Trigger>
                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource MapEditorAccentBrush}" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MapEditorSelectorButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="Background" Value="{StaticResource MapEditorInsetBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource MapEditorStrokeBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{StaticResource MapEditorTextPrimaryBrush}" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="24" />
                                </Grid.ColumnDefinitions>
                                <ContentPresenter Margin="{TemplateBinding Padding}"
                                                  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                                <ui:SymbolIcon Grid.Column="1"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               FontSize="14"
                                               Foreground="{StaticResource MapEditorTextSecondaryBrush}"
                                               Symbol="ChevronRight16" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="#6639DCEB" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#B0147884" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModeSegmentButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource MapEditorTextPrimaryBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Margin="0"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#26313B" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DebugModeSegmentButtonStyle"
               BasedOn="{StaticResource ModeSegmentButtonStyle}"
               TargetType="Button">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsDebugMode}" Value="True">
                    <Setter Property="Background" Value="#B0147884" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="RecorderModeSegmentButtonStyle"
               BasedOn="{StaticResource ModeSegmentButtonStyle}"
               TargetType="Button">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsRecorderMode}" Value="True">
                    <Setter Property="Background" Value="#B0147884" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </ui:FluentWindow.Resources>

    <Grid Background="#FF0E1114">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="实时追踪地图 - 路线录制编辑器">
            <ui:TitleBar.Icon>
                <ui:ImageIcon Source="pack://application:,,,/Resources/Images/logo.png" />
            </ui:TitleBar.Icon>
            <ui:TitleBar.TrailingContent>
                <StackPanel Height="32"
                            VerticalAlignment="Top"
                            Orientation="Horizontal">
                    <Button x:Name="TitleTopmostButton"
                            Width="38"
                            Height="32"
                            Margin="0,0,4,0"
                            Padding="0"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            Click="TitleTopmostButton_Click"
                            Focusable="False">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="ToolTip" Value="窗口置顶" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsTopmost}" Value="True">
                                        <Setter Property="ToolTip" Value="取消置顶" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <ui:SymbolIcon FontSize="20">
                            <ui:SymbolIcon.Style>
                                <Style TargetType="ui:SymbolIcon">
                                    <Setter Property="Symbol" Value="PinOff28" />
                                    <Setter Property="Foreground" Value="#D7E4EA" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsTopmost}" Value="True">
                                            <Setter Property="Symbol" Value="Pin28" />
                                            <Setter Property="Foreground" Value="{StaticResource MapEditorAccentBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ui:SymbolIcon.Style>
                        </ui:SymbolIcon>
                    </Button>
                    <ui:Button Width="38"
                               Height="32"
                               Margin="0,0,4,0"
                               Padding="0"
                               Appearance="Transparent"
                               Background="Transparent"
                               BorderBrush="Transparent"
                               Command="{Binding ToggleSidePanelCommand}"
                               CornerRadius="0"
                               Focusable="False"
                               ToolTip="{Binding SidePanelToggleText}">
                        <ui:SymbolIcon FontSize="18"
                                       Foreground="#9FB0C0">
                            <ui:SymbolIcon.Style>
                                <Style TargetType="ui:SymbolIcon">
                                    <Setter Property="Symbol" Value="ArrowRight24" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSidePanelVisible}" Value="False">
                                            <Setter Property="Symbol" Value="ArrowLeft24" />
                                            <Setter Property="Foreground" Value="{StaticResource MapEditorAccentBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ui:SymbolIcon.Style>
                        </ui:SymbolIcon>
                    </ui:Button>
                </StackPanel>
            </ui:TitleBar.TrailingContent>
        </ui:TitleBar>

        <Grid x:Name="MainLayoutGrid"
              Grid.Row="1"
              Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="MapColumn"
                                  Width="*"
                                  MinWidth="420" />
                <ColumnDefinition x:Name="SplitterColumn" Width="6" />
                <ColumnDefinition x:Name="SideColumn"
                                  Width="580"
                                  MinWidth="520" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="#FF101820"
                    BorderBrush="#33405A64"
                    BorderThickness="1"
                    CornerRadius="6">
                <Grid>
                    <controls:MapTileViewerControl x:Name="TileMap"
                                                   HorizontalAlignment="Stretch"
                                                   VerticalAlignment="Stretch"
                                                   FollowZoom="{Binding FollowZoom}"
                                                   IsPathRecorderRecording="{Binding IsPathRecorderRecording}"
                                                   IsRecorderMode="{Binding IsRecorderMode}"
                                                   MapName="{Binding MapName}"
                                                   ShowTeleportPoints="{Binding ShowTeleportPoints}">
                        <controls:MapTileViewerControl.ContextMenu>
                            <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                <ui:MenuItem Command="{Binding InsertWaypointOnSelectedRecorderEdgeFromMenuCommand}"
                                             Header="插入新点"
                                             Icon="{ui:SymbolIcon Add24}"
                                             InputGestureText="Enter"
                                             Visibility="{Binding MapEdgeContextMenuVisibility}" />
                                <ui:MenuItem Command="{Binding FitSelectedRecorderEdgeCommand}"
                                             Header="定位到插入点"
                                             Icon="{ui:SymbolIcon Location24}"
                                             Visibility="{Binding MapEdgeContextMenuVisibility}" />
                                <ui:MenuItem Command="{Binding ReverseSelectedRecorderEdgeCommand}"
                                             Header="反转线段两端"
                                             Icon="{ui:SymbolIcon ArrowBidirectionalLeftRight24}"
                                             Visibility="{Binding MapEdgeContextMenuVisibility}" />
                                <ui:MenuItem Command="{Binding ClearSelectedRecorderEdgeSelectionCommand}"
                                             Header="取消线段选择"
                                             Icon="{ui:SymbolIcon Dismiss24}"
                                             Visibility="{Binding MapEdgeContextMenuVisibility}" />
                                <Separator Visibility="{Binding MapEdgeContextMenuVisibility}" />
                                <ui:MenuItem Command="{Binding RunRecordingFromWaypointCommand}"
                                             CommandParameter="{Binding SelectedRecordedWaypoint}"
                                             Header="从此点运行"
                                             Icon="{ui:SymbolIcon Play24}"
                                             Visibility="{Binding MapWaypointContextMenuVisibility}" />
                                <ui:MenuItem Command="{Binding ToggleWaypointLockCommand}"
                                             CommandParameter="{Binding SelectedRecordedWaypoint}"
                                             Header="设为插入位置"
                                             Icon="{ui:SymbolIcon Location24}"
                                             Visibility="{Binding MapWaypointContextMenuVisibility}" />
                                <ui:MenuItem Command="{Binding OpenWaypointAdvancedEditorCommand}"
                                             CommandParameter="{Binding SelectedRecordedWaypoint}"
                                             Header="高级信息"
                                             Icon="{ui:SymbolIcon Settings24}"
                                             Visibility="{Binding MapWaypointContextMenuVisibility}" />
                                <Separator Visibility="{Binding MapWaypointContextMenuVisibility}" />
                                <ui:MenuItem Command="{Binding CopyWaypointSelectionCommand}"
                                             Header="复制选中"
                                             Icon="{ui:SymbolIcon Copy24}"
                                             InputGestureText="Ctrl+C"
                                             Visibility="{Binding MapWaypointContextMenuVisibility}" />
                                <ui:MenuItem Command="{Binding CutWaypointSelectionCommand}"
                                             Header="剪切选中"
                                             Icon="{ui:SymbolIcon Cut24}"
                                             InputGestureText="Ctrl+X"
                                             Visibility="{Binding MapWaypointContextMenuVisibility}" />
                                <ui:MenuItem Command="{Binding PasteWaypointSelectionCommand}"
                                             Header="粘贴到选中后"
                                             Icon="{ui:SymbolIcon ClipboardPaste24}"
                                             InputGestureText="Ctrl+V"
                                             Visibility="{Binding MapWaypointContextMenuVisibility}" />
                                <ui:MenuItem Command="{Binding DuplicateWaypointSelectionCommand}"
                                             Header="复制并插入"
                                             Icon="{ui:SymbolIcon CopyAdd24}"
                                             InputGestureText="Ctrl+D"
                                             Visibility="{Binding MapWaypointContextMenuVisibility}" />
                                <ui:MenuItem Command="{Binding DeleteWaypointSelectionCommand}"
                                             Foreground="{StaticResource MapEditorDangerBrush}"
                                             Header="删除选中"
                                             Icon="{ui:SymbolIcon Delete24}"
                                             InputGestureText="Delete"
                                             Visibility="{Binding MapWaypointContextMenuVisibility}" />
                                <Separator Visibility="{Binding MapWaypointContextMenuVisibility}" />
                                <ui:MenuItem Command="{Binding MoveRecordedWaypointUpCommand}"
                                             CommandParameter="{Binding SelectedRecordedWaypoint}"
                                             Header="上移"
                                             Icon="{ui:SymbolIcon ArrowUp24}"
                                             Visibility="{Binding MapWaypointContextMenuVisibility}" />
                                <ui:MenuItem Command="{Binding MoveRecordedWaypointDownCommand}"
                                             CommandParameter="{Binding SelectedRecordedWaypoint}"
                                             Header="下移"
                                             Icon="{ui:SymbolIcon ArrowDown24}"
                                             Visibility="{Binding MapWaypointContextMenuVisibility}" />
                                <Separator Visibility="{Binding MapWaypointContextMenuVisibility}" />
                                <ui:MenuItem Command="{Binding ClearWaypointSelectionCommand}"
                                             Header="取消选择"
                                             Icon="{ui:SymbolIcon Dismiss24}"
                                             Visibility="{Binding MapWaypointContextMenuVisibility}" />
                            </ContextMenu>
                        </controls:MapTileViewerControl.ContextMenu>
                    </controls:MapTileViewerControl>

                    <Border HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            Margin="18"
                            Style="{StaticResource OverlayCardStyle}">
                        <Grid Width="230">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <ui:SymbolIcon VerticalAlignment="Center"
                                           Foreground="#D7E4EA"
                                           Symbol="Search24" />
                            <TextBlock Grid.Column="1"
                                       Margin="10,0,0,0"
                                       VerticalAlignment="Center"
                                       FontWeight="SemiBold"
                                       Foreground="#D7E4EA"
                                       Text="{Binding SelectedTargetText}"
                                       TextTrimming="CharacterEllipsis" />
                        </Grid>
                    </Border>

                    <Border HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Margin="18,0,0,0"
                            Background="#D9111820"
                            BorderBrush="#4039DCEB"
                            BorderThickness="1"
                            CornerRadius="6">
                        <StackPanel Width="44">
                            <Button Command="{Binding ZoomInCommand}"
                                    Style="{StaticResource MapToolButtonStyle}"
                                    ToolTip="放大地图">
                                <ui:SymbolIcon FontSize="18"
                                               Foreground="#D7E4EA"
                                               Symbol="Add24" />
                            </Button>
                            <Rectangle Height="1" Fill="#26313B" />
                            <Border Width="42"
                                    Height="30"
                                    Background="#33111923"
                                    ToolTip="当前缩放">
                                <TextBlock HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontSize="11"
                                           Foreground="#D7E4EA"
                                           Text="{Binding MapZoomText}" />
                            </Border>
                            <Rectangle Height="1" Fill="#26313B" />
                            <Button Command="{Binding ZoomOutCommand}"
                                    Style="{StaticResource MapToolButtonStyle}"
                                    ToolTip="缩小地图">
                                <ui:SymbolIcon FontSize="18"
                                               Foreground="#D7E4EA"
                                               Symbol="Subtract24" />
                            </Button>
                            <Rectangle Height="1" Fill="#26313B" />
                            <Button Command="{Binding RefreshCurrentViewCommand}"
                                    Style="{StaticResource MapToolButtonStyle}"
                                    ToolTip="定位当前">
                                <ui:SymbolIcon FontSize="18"
                                               Foreground="#D7E4EA"
                                               Symbol="Location24" />
                            </Button>
                            <Rectangle Height="1" Fill="#26313B" />
                            <Button Command="{Binding ClearPathingCommand}"
                                    Style="{StaticResource MapToolButtonStyle}"
                                    ToolTip="清除目标与路径">
                                <ui:SymbolIcon FontSize="18"
                                               Foreground="#D7E4EA"
                                               Symbol="Dismiss24" />
                            </Button>
                            <Rectangle Height="1"
                                       Fill="#26313B"
                                       Visibility="{Binding RecorderMainVisibility}" />
                            <Button Command="{Binding ToggleMapClickEditModeCommand}"
                                    ToolTip="{Binding MapClickEditModeToolTip}"
                                    Visibility="{Binding RecorderMainVisibility}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource MapToolButtonStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding UpdateSelectedPointOnMapClick}" Value="True">
                                                <Setter Property="Background" Value="#B0147884" />
                                                <Setter Property="BorderBrush" Value="{StaticResource MapEditorAccentBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <ui:SymbolIcon FontSize="18"
                                               Symbol="Edit24">
                                    <ui:SymbolIcon.Style>
                                        <Style TargetType="ui:SymbolIcon">
                                            <Setter Property="Foreground" Value="#D7E4EA" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding UpdateSelectedPointOnMapClick}" Value="True">
                                                    <Setter Property="Foreground" Value="{StaticResource MapEditorAccentBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ui:SymbolIcon.Style>
                                </ui:SymbolIcon>
                            </Button>
                        </StackPanel>
                    </Border>

                    <Border HorizontalAlignment="Left"
                            VerticalAlignment="Bottom"
                            Margin="18"
                            Style="{StaticResource OverlayCardStyle}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Foreground="#D7E4EA" Text="{Binding MapStatusText}" />
                        </StackPanel>
                    </Border>

                    <Border HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Margin="18"
                            Visibility="{Binding SidePanelHiddenVisibility}">
                        <ui:Button Width="38"
                                   Height="34"
                                   Padding="0"
                                   Appearance="Transparent"
                                   Background="#D9111820"
                                   BorderBrush="#4039DCEB"
                                   Command="{Binding ToggleSidePanelCommand}"
                                   Icon="{ui:SymbolIcon ArrowLeft24}"
                                   ToolTip="显示侧栏" />
                    </Border>

                    <Border HorizontalAlignment="Right"
                            VerticalAlignment="Bottom"
                            Margin="18"
                            Padding="8,6"
                            Style="{StaticResource OverlayCardStyle}">
                        <StackPanel Width="214">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock VerticalAlignment="Center"
                                           Style="{StaticResource CaptionTextStyle}"
                                           Text="地图：" />
                                <ComboBox Grid.Column="1"
                                          Height="34"
                                          ItemTemplate="{StaticResource MapEditorOptionTemplate}"
                                          ItemContainerStyle="{StaticResource MapEditorComboBoxItemStyle}"
                                          ItemsSource="{Binding MapLayerOptions}"
                                          SelectedValue="{Binding MapName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          SelectedValuePath="Code"
                                          Style="{StaticResource MapEditorComboBoxStyle}" />
                            </Grid>
                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock VerticalAlignment="Center"
                                           Style="{StaticResource CaptionTextStyle}"
                                           Text="跟随" />
                                <ui:ToggleSwitch Grid.Column="1"
                                                 VerticalAlignment="Center"
                                                 IsChecked="{Binding IsFollowingCurrent, Mode=TwoWay}"
                                                 ToolTip="{Binding FollowHotkeyText, StringFormat=跟随当前坐标（{0}）}" />
                                <TextBlock Grid.Column="3"
                                           VerticalAlignment="Center"
                                           Style="{StaticResource CaptionTextStyle}"
                                           Text="传送点" />
                                <ui:ToggleSwitch Grid.Column="4"
                                                 VerticalAlignment="Center"
                                                 IsChecked="{Binding ShowTeleportPoints, Mode=TwoWay}"
                                                 ToolTip="显示传送点" />
                            </Grid>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <GridSplitter x:Name="SidePanelSplitter"
                          Grid.Column="1"
                          Width="6"
                          HorizontalAlignment="Center"
                          Background="Transparent"
                          DragCompleted="SidePanelSplitter_DragCompleted"
                          ResizeBehavior="PreviousAndNext"
                          ResizeDirection="Columns"
                          ShowsPreview="True"
                          Visibility="{Binding SidePanelVisibility}" />

            <Border Grid.Column="2"
                    Background="{StaticResource MapEditorPanelBrush}"
                    BorderBrush="{StaticResource MapEditorStrokeBrush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Visibility="{Binding SidePanelVisibility}">
                <Grid x:Name="SidePanelContentGrid"
                      Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource PanelCardStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="260" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="220" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid Grid.Column="0" HorizontalAlignment="Stretch">
                                <Border Padding="3"
                                        Background="{StaticResource MapEditorInsetBrush}"
                                        BorderBrush="{StaticResource MapEditorStrokeBrush}"
                                        BorderThickness="1"
                                        CornerRadius="5">
                                    <UniformGrid Columns="2">
                                        <Button Margin="0,0,2,0"
                                                Command="{Binding SwitchToDebugModeCommand}"
                                                Content="调试"
                                                Style="{StaticResource DebugModeSegmentButtonStyle}" />
                                        <Button Margin="2,0,0,0"
                                                Command="{Binding SwitchToRecorderModeCommand}"
                                                Content="录制"
                                                Style="{StaticResource RecorderModeSegmentButtonStyle}" />
                                    </UniformGrid>
                                </Border>
                            </Grid>
                            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                <ui:Button Height="38"
                                           HorizontalAlignment="Stretch"
                                           Command="{Binding RunModeActionCommand}"
                                           Content="{Binding ModeActionText}"
                                           ToolTip="{Binding ModeActionToolTip}">
                                    <ui:Button.Icon>
                                        <ui:SymbolIcon>
                                            <ui:SymbolIcon.Style>
                                                <Style TargetType="ui:SymbolIcon">
                                                    <Setter Property="Symbol" Value="Play24" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsRecorderMode}" Value="True">
                                                            <Setter Property="Symbol" Value="Record24" />
                                                        </DataTrigger>
                                                        <MultiDataTrigger>
                                                            <MultiDataTrigger.Conditions>
                                                                <Condition Binding="{Binding IsRecorderMode}" Value="True" />
                                                                <Condition Binding="{Binding IsPathRecorderRecording}" Value="True" />
                                                            </MultiDataTrigger.Conditions>
                                                            <Setter Property="Symbol" Value="Stop24" />
                                                        </MultiDataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ui:SymbolIcon.Style>
                                        </ui:SymbolIcon>
                                    </ui:Button.Icon>
                                </ui:Button>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1"
                          Margin="0,8,0,8"
                          Visibility="{Binding RecorderMainVisibility}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Style="{StaticResource PanelCardStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <StackPanel x:Name="RouteMenuBar"
                                            Orientation="Horizontal">
                                    <ui:DropDownButton Content="文件(F)"
                                                       Style="{StaticResource MapEditorMenuButtonStyle}">
                                        <ui:DropDownButton.Flyout>
                                            <ContextMenu>
                                                <ui:MenuItem Command="{Binding NewRecordingCommand}"
                                                             Header="新建路线"
                                                             Icon="{ui:SymbolIcon Add24}"
                                                             InputGestureText="Ctrl+N" />
                                                <ui:MenuItem Command="{Binding ImportRecordingCommand}"
                                                             Header="浏览导入"
                                                             Icon="{ui:SymbolIcon FolderOpen24}"
                                                             InputGestureText="Ctrl+O" />
                                                <ui:MenuItem Command="{Binding ImportFromSystemDialogCommand}"
                                                             Header="系统导入"
                                                             Icon="{ui:SymbolIcon Document24}" />
                                                <ui:MenuItem Command="{Binding ImportAndMergeRecordingsCommand}"
                                                             Header="合并导入"
                                                             Icon="{ui:SymbolIcon Archive24}"
                                                             InputGestureText="Ctrl+Shift+O" />
                                                <ui:MenuItem Command="{Binding OpenLegacyRecorderEditorCommand}"
                                                             Header="旧版录制编辑器"
                                                             Icon="{ui:SymbolIcon ClipboardTask24}" />
                                                <Separator />
                                                <ui:MenuItem Command="{Binding SaveRecordingCommand}"
                                                             Header="保存"
                                                             Icon="{ui:SymbolIcon Save24}"
                                                             InputGestureText="Ctrl+S" />
                                                <ui:MenuItem Command="{Binding SaveRecordingAsCommand}"
                                                             Header="另存为"
                                                             Icon="{ui:SymbolIcon Save24}"
                                                             InputGestureText="Ctrl+Shift+S" />
                                            </ContextMenu>
                                        </ui:DropDownButton.Flyout>
                                    </ui:DropDownButton>

                                    <ui:DropDownButton x:Name="EditMenuButton"
                                                       Content="编辑(E)"
                                                       Style="{StaticResource MapEditorMenuButtonStyle}">
                                        <ui:DropDownButton.Flyout>
                                            <ContextMenu>
                                                <ui:MenuItem Command="{Binding UndoRecorderEditCommand}"
                                                             Header="撤销"
                                                             Icon="{ui:SymbolIcon ArrowUndo24}"
                                                             InputGestureText="Ctrl+Z" />
                                                <ui:MenuItem Command="{Binding RedoRecorderEditCommand}"
                                                             Header="重做"
                                                             Icon="{ui:SymbolIcon ArrowRedo24}"
                                                             InputGestureText="Ctrl+Y" />
                                                <Separator />
                                                <ui:MenuItem Command="{Binding CopyWaypointSelectionCommand}"
                                                             Header="复制点位"
                                                             Icon="{ui:SymbolIcon Copy24}"
                                                             InputGestureText="Ctrl+C" />
                                                <ui:MenuItem Command="{Binding CutWaypointSelectionCommand}"
                                                             Header="剪切点位"
                                                             Icon="{ui:SymbolIcon Cut24}"
                                                             InputGestureText="Ctrl+X" />
                                                <ui:MenuItem Command="{Binding PasteWaypointSelectionCommand}"
                                                             Header="粘贴点位"
                                                             Icon="{ui:SymbolIcon ClipboardPaste24}"
                                                             InputGestureText="Ctrl+V" />
                                                <ui:MenuItem Command="{Binding DuplicateWaypointSelectionCommand}"
                                                             Header="复制并插入"
                                                             Icon="{ui:SymbolIcon CopyAdd24}"
                                                             InputGestureText="Ctrl+D" />
                                                <ui:MenuItem Command="{Binding DeleteWaypointSelectionCommand}"
                                                             Foreground="{StaticResource MapEditorDangerBrush}"
                                                             Header="删除点位"
                                                             Icon="{ui:SymbolIcon Delete24}"
                                                             InputGestureText="Delete" />
                                                <ui:MenuItem Command="{Binding ClearRecordedWaypointsCommand}"
                                                             Foreground="{StaticResource MapEditorDangerBrush}"
                                                             Header="清空点位"
                                                             Icon="{ui:SymbolIcon Delete24}" />
                                                <Separator />
                                                <ui:MenuItem Command="{Binding OpenRecorderPreferencesCommand}"
                                                             Header="首选项"
                                                             Icon="{ui:SymbolIcon Settings24}" />
                                                <Separator />
                                                <ui:MenuItem Command="{Binding SwitchToRecorderUiEditorCommand}"
                                                             Header="表单编辑"
                                                             Icon="{ui:SymbolIcon Form24}" />
                                                <ui:MenuItem Command="{Binding SwitchToRecorderJsonEditorCommand}"
                                                             Header="JSON 编辑"
                                                             Icon="{ui:SymbolIcon ClipboardTask24}" />
                                            </ContextMenu>
                                        </ui:DropDownButton.Flyout>
                                    </ui:DropDownButton>

                                    <Popup AllowsTransparency="True"
                                           DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}"
                                           IsOpen="{Binding IsRecorderPreferencesOpen, Mode=TwoWay}"
                                           Placement="Center"
                                           PlacementTarget="{Binding ElementName=MainLayoutGrid}"
                                           StaysOpen="False">
                                        <Border Width="640"
                                                MaxHeight="660"
                                                Padding="16"
                                                Background="#FF1A2025"
                                                BorderBrush="{StaticResource MapEditorStrokeBrush}"
                                                BorderThickness="1"
                                                CornerRadius="8">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>
                                                <Grid Margin="0,0,0,14">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel>
                                                        <TextBlock FontSize="16"
                                                                   FontWeight="SemiBold"
                                                                   Text="首选项" />
                                                        <TextBlock Margin="0,4,0,0"
                                                                   Style="{StaticResource CaptionTextStyle}"
                                                                   Text="录制编辑器的长期偏好和作者库维护" />
                                                    </StackPanel>
                                                    <ui:Button Grid.Column="1"
                                                               Width="32"
                                                               Height="32"
                                                               Padding="0"
                                                               Appearance="Transparent"
                                                               Background="#1F2830"
                                                               BorderBrush="{StaticResource MapEditorStrokeBrush}"
                                                               Command="{Binding CloseRecorderPreferencesCommand}"
                                                               Icon="{ui:SymbolIcon Dismiss24}" />
                                                </Grid>

                                                <ScrollViewer Grid.Row="1"
                                                              MaxHeight="570"
                                                              VerticalScrollBarVisibility="Auto">
                                                    <StackPanel>
                                                        <Border Padding="14"
                                                                Background="{StaticResource MapEditorInsetBrush}"
                                                                BorderBrush="{StaticResource MapEditorStrokeBrush}"
                                                                BorderThickness="1"
                                                                CornerRadius="6">
                                                            <Grid>
                                                                <Grid.RowDefinitions>
                                                                    <RowDefinition Height="Auto" />
                                                                    <RowDefinition Height="12" />
                                                                    <RowDefinition Height="Auto" />
                                                                    <RowDefinition Height="10" />
                                                                    <RowDefinition Height="Auto" />
                                                                    <RowDefinition Height="10" />
                                                                    <RowDefinition Height="Auto" />
                                                                </Grid.RowDefinitions>
                                                                <TextBlock FontWeight="SemiBold" Text="编辑偏好" />

                                                                <Grid Grid.Row="2">
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="*" />
                                                                        <ColumnDefinition Width="120" />
                                                                    </Grid.ColumnDefinitions>
                                                                    <StackPanel VerticalAlignment="Center">
                                                                        <TextBlock Text="微调步长" />
                                                                        <TextBlock Margin="0,4,16,0"
                                                                                   Style="{StaticResource CaptionTextStyle}"
                                                                                   Text="方向键 / WASD 每次移动的原神游戏坐标"
                                                                                   TextWrapping="Wrap" />
                                                                    </StackPanel>
                                                                    <ui:TextBox Grid.Column="1"
                                                                                Height="34"
                                                                                HorizontalContentAlignment="Right"
                                                                                Background="{StaticResource MapEditorInsetBrush}"
                                                                                Foreground="{StaticResource MapEditorTextPrimaryBrush}"
                                                                                Style="{StaticResource FormTextBoxStyle}"
                                                                                Text="{Binding RecorderNudgeStepText, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                                                                </Grid>

                                                                <Grid Grid.Row="4">
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="*" />
                                                                        <ColumnDefinition Width="Auto" />
                                                                    </Grid.ColumnDefinitions>
                                                                    <StackPanel VerticalAlignment="Center">
                                                                        <TextBlock Text="地图点击更新选中点" />
                                                                        <TextBlock Margin="0,4,16,0"
                                                                                   Style="{StaticResource CaptionTextStyle}"
                                                                                   Text="开启后点击地图会更新当前选中路线点；可用 Tab 快速切换"
                                                                                   TextWrapping="Wrap" />
                                                                    </StackPanel>
                                                                    <ui:ToggleSwitch Grid.Column="1"
                                                                                     VerticalAlignment="Center"
                                                                                     IsChecked="{Binding UpdateSelectedPointOnMapClick, Mode=TwoWay}"
                                                                                     ToolTip="{Binding MapClickEditModeToolTip}" />
                                                                </Grid>

                                                                <Grid Grid.Row="6">
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="*" />
                                                                        <ColumnDefinition Width="Auto" />
                                                                    </Grid.ColumnDefinitions>
                                                                    <StackPanel VerticalAlignment="Center">
                                                                        <TextBlock Text="地图辅助显示" />
                                                                        <TextBlock Margin="0,4,16,0"
                                                                                   Style="{StaticResource CaptionTextStyle}"
                                                                                   Text="这些开关也保留在地图右下角，方便录制时临时切换"
                                                                                   TextWrapping="Wrap" />
                                                                    </StackPanel>
                                                                    <StackPanel Grid.Column="1"
                                                                                MinWidth="170">
                                                                        <Grid>
                                                                            <Grid.ColumnDefinitions>
                                                                                <ColumnDefinition Width="*" />
                                                                                <ColumnDefinition Width="Auto" />
                                                                            </Grid.ColumnDefinitions>
                                                                            <TextBlock VerticalAlignment="Center"
                                                                                       Style="{StaticResource CaptionTextStyle}"
                                                                                       Text="跟随当前坐标" />
                                                                            <ui:ToggleSwitch Grid.Column="1"
                                                                                             VerticalAlignment="Center"
                                                                                             IsChecked="{Binding IsFollowingCurrent, Mode=TwoWay}"
                                                                                             ToolTip="{Binding FollowHotkeyText, StringFormat=跟随当前坐标（{0}）}" />
                                                                        </Grid>
                                                                        <Grid Margin="0,8,0,0">
                                                                            <Grid.ColumnDefinitions>
                                                                                <ColumnDefinition Width="*" />
                                                                                <ColumnDefinition Width="Auto" />
                                                                            </Grid.ColumnDefinitions>
                                                                            <TextBlock VerticalAlignment="Center"
                                                                                       Style="{StaticResource CaptionTextStyle}"
                                                                                       Text="显示传送点" />
                                                                            <ui:ToggleSwitch Grid.Column="1"
                                                                                             VerticalAlignment="Center"
                                                                                             IsChecked="{Binding ShowTeleportPoints, Mode=TwoWay}"
                                                                                             ToolTip="显示传送点" />
                                                                        </Grid>
                                                                    </StackPanel>
                                                                </Grid>
                                                            </Grid>
                                                        </Border>

                                                        <Border Margin="0,12,0,0"
                                                                Padding="14"
                                                                Background="{StaticResource MapEditorInsetBrush}"
                                                                BorderBrush="{StaticResource MapEditorStrokeBrush}"
                                                                BorderThickness="1"
                                                                CornerRadius="6">
                                                            <Grid>
                                                                <Grid.RowDefinitions>
                                                                    <RowDefinition Height="Auto" />
                                                                    <RowDefinition Height="12" />
                                                                    <RowDefinition Height="Auto" />
                                                                    <RowDefinition Height="12" />
                                                                    <RowDefinition Height="Auto" />
                                                                    <RowDefinition Height="12" />
                                                                    <RowDefinition Height="Auto" />
                                                                </Grid.RowDefinitions>

                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="*" />
                                                                        <ColumnDefinition Width="Auto" />
                                                                    </Grid.ColumnDefinitions>
                                                                    <StackPanel>
                                                                        <TextBlock FontWeight="SemiBold" Text="作者偏好" />
                                                                        <TextBlock Margin="0,4,16,0"
                                                                                   Style="{StaticResource CaptionTextStyle}"
                                                                                   Text="{Binding CommonRecordAuthorSummaryText}" />
                                                                    </StackPanel>
                                                                    <ui:Button Grid.Column="1"
                                                                               Width="112"
                                                                               Height="32"
                                                                               Command="{Binding ImportCommonRecordAuthorsFromLibraryCommand}"
                                                                               Content="导入作者库"
                                                                               Icon="{ui:SymbolIcon FolderOpen24}" />
                                                                </Grid>

                                                                <Grid Grid.Row="2">
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="*" />
                                                                        <ColumnDefinition Width="8" />
                                                                        <ColumnDefinition Width="Auto" />
                                                                        <ColumnDefinition Width="8" />
                                                                        <ColumnDefinition Width="Auto" />
                                                                    </Grid.ColumnDefinitions>
                                                                    <ComboBox Height="34"
                                                                              DisplayMemberPath="DisplayText"
                                                                              ItemsSource="{Binding CommonRecordAuthors}"
                                                                              SelectedItem="{Binding SelectedCommonRecordAuthor, Mode=TwoWay}"
                                                                              Style="{StaticResource MapEditorComboBoxStyle}"
                                                                              ToolTip="{Binding SelectedCommonRecordAuthor.DetailText}" />
                                                                    <ui:Button Grid.Column="2"
                                                                               Width="96"
                                                                               Height="34"
                                                                               Command="{Binding SetDefaultAuthorFromSelectedCommonCommand}"
                                                                               Content="设为默认"
                                                                               Icon="{ui:SymbolIcon Person24}" />
                                                                    <ui:Button Grid.Column="4"
                                                                               Width="72"
                                                                               Height="34"
                                                                               Command="{Binding DeleteCommonRecordAuthorCommand}"
                                                                               Content="删除"
                                                                               Foreground="{StaticResource MapEditorDangerBrush}"
                                                                               Icon="{ui:SymbolIcon Delete24}" />
                                                                </Grid>

                                                                <Grid Grid.Row="4">
                                                                    <Grid.RowDefinitions>
                                                                        <RowDefinition Height="Auto" />
                                                                        <RowDefinition Height="8" />
                                                                        <RowDefinition Height="Auto" />
                                                                    </Grid.RowDefinitions>
                                                                    <TextBlock FontWeight="SemiBold" Text="默认作者" />
                                                                    <Grid Grid.Row="2">
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="*" />
                                                                            <ColumnDefinition Width="8" />
                                                                            <ColumnDefinition Width="*" />
                                                                            <ColumnDefinition Width="8" />
                                                                            <ColumnDefinition Width="Auto" />
                                                                        </Grid.ColumnDefinitions>
                                                                        <ui:TextBox Height="34"
                                                                                    PlaceholderText="默认作者名称"
                                                                                    Style="{StaticResource FormTextBoxStyle}"
                                                                                    Text="{Binding DefaultRecordAuthorName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                                        <ui:TextBox Grid.Column="2"
                                                                                    Height="34"
                                                                                    PlaceholderText="默认链接（可选）"
                                                                                    Style="{StaticResource FormTextBoxStyle}"
                                                                                    Text="{Binding DefaultRecordAuthorLinks, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                                        <ui:Button Grid.Column="4"
                                                                                   Width="96"
                                                                                   Height="34"
                                                                                   Command="{Binding AddDefaultAuthorToCommonCommand}"
                                                                                   Content="加入常用"
                                                                                   Icon="{ui:SymbolIcon Person24}" />
                                                                    </Grid>
                                                                </Grid>

                                                                <Grid Grid.Row="6">
                                                                    <Grid.RowDefinitions>
                                                                        <RowDefinition Height="Auto" />
                                                                        <RowDefinition Height="8" />
                                                                        <RowDefinition Height="Auto" />
                                                                    </Grid.RowDefinitions>
                                                                    <TextBlock FontWeight="SemiBold" Text="新增常用作者" />
                                                                    <Grid Grid.Row="2">
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="*" />
                                                                            <ColumnDefinition Width="8" />
                                                                            <ColumnDefinition Width="*" />
                                                                            <ColumnDefinition Width="8" />
                                                                            <ColumnDefinition Width="Auto" />
                                                                        </Grid.ColumnDefinitions>
                                                                        <ui:TextBox Height="34"
                                                                                    PlaceholderText="作者名称"
                                                                                    Style="{StaticResource FormTextBoxStyle}"
                                                                                    Text="{Binding NewCommonAuthorName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                                        <ui:TextBox Grid.Column="2"
                                                                                    Height="34"
                                                                                    PlaceholderText="链接"
                                                                                    Style="{StaticResource FormTextBoxStyle}"
                                                                                    Text="{Binding NewCommonAuthorLinks, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                                        <ui:Button Grid.Column="4"
                                                                                   Width="72"
                                                                                   Height="34"
                                                                                   Command="{Binding AddCustomCommonAuthorCommand}"
                                                                                   Content="添加"
                                                                                   Icon="{ui:SymbolIcon Add24}" />
                                                                    </Grid>
                                                                </Grid>
                                                            </Grid>
                                                        </Border>
                                                    </StackPanel>
                                                </ScrollViewer>
                                            </Grid>
                                        </Border>
                                    </Popup>

                                    <ui:DropDownButton Content="选择(S)"
                                                       Style="{StaticResource MapEditorMenuButtonStyle}">
                                        <ui:DropDownButton.Flyout>
                                            <ContextMenu>
                                                <ui:MenuItem Command="{Binding SelectAllWaypointSelectionCommand}"
                                                             Header="全选点位"
                                                             Icon="{ui:SymbolIcon SelectAllOn24}"
                                                             InputGestureText="Ctrl+A" />
                                                <ui:MenuItem Command="{Binding ClearWaypointSelectionCommand}"
                                                             Header="取消点位选择"
                                                             Icon="{ui:SymbolIcon Dismiss24}" />
                                            </ContextMenu>
                                        </ui:DropDownButton.Flyout>
                                    </ui:DropDownButton>

                                    <ui:DropDownButton x:Name="ViewMenuButton"
                                                       Content="查看(V)"
                                                       Style="{StaticResource MapEditorMenuButtonStyle}">
                                        <ui:DropDownButton.Flyout>
                                            <ContextMenu>
                                                <ui:MenuItem Command="{Binding OpenOperationLogCommand}"
                                                             Header="操作日志"
                                                             Icon="{ui:SymbolIcon Document24}" />
                                                <Separator />
                                                <ui:MenuItem Header="地图小窗"
                                                             Icon="{ui:SymbolIcon PanelRight24}"
                                                             InputGestureText="{Binding MiniFollow.HotkeyText}"
                                                             IsCheckable="True"
                                                             IsChecked="{Binding MiniFollow.IsVisible, Mode=TwoWay}" />
                                                <Separator />
                                                <ui:MenuItem Command="{Binding ToggleSidePanelCommand}"
                                                             Header="显示/隐藏侧栏"
                                                             Icon="{ui:SymbolIcon PanelRight24}" />
                                                <ui:MenuItem Command="{Binding RefreshCurrentViewCommand}"
                                                             Header="定位当前"
                                                             Icon="{ui:SymbolIcon Location24}" />
                                                <ui:MenuItem Header="地图层级"
                                                             Icon="{ui:SymbolIcon Stack24}"
                                                             ItemsSource="{Binding MapLayerOptions}">
                                                    <ui:MenuItem.ItemContainerStyle>
                                                        <Style TargetType="MenuItem">
                                                            <Setter Property="Header" Value="{Binding DisplayName}" />
                                                            <Setter Property="Command"
                                                                    Value="{Binding DataContext.SetMapLayerCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                                            <Setter Property="CommandParameter" Value="{Binding}" />
                                                        </Style>
                                                    </ui:MenuItem.ItemContainerStyle>
                                                </ui:MenuItem>
                                                <ui:MenuItem Command="{Binding ClearPathingCommand}"
                                                             Header="清除目标与路径"
                                                             Icon="{ui:SymbolIcon Dismiss24}" />
                                                <ui:MenuItem Header="显示传送点"
                                                             Icon="{ui:SymbolIcon Location24}"
                                                             IsCheckable="True"
                                                             IsChecked="{Binding ShowTeleportPoints, Mode=TwoWay}" />
                                            </ContextMenu>
                                        </ui:DropDownButton.Flyout>
                                    </ui:DropDownButton>
                                </StackPanel>

                                <Popup AllowsTransparency="True"
                                       DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}"
                                       HorizontalOffset="-160"
                                       IsOpen="{Binding IsOperationLogOpen, Mode=TwoWay}"
                                       Placement="Bottom"
                                       PlacementTarget="{Binding ElementName=ViewMenuButton}"
                                       StaysOpen="False">
                                    <Border Width="440"
                                            MaxHeight="480"
                                            Padding="14"
                                            Background="#FF1A2025"
                                            BorderBrush="{StaticResource MapEditorStrokeBrush}"
                                            BorderThickness="1"
                                            CornerRadius="6">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="*" />
                                            </Grid.RowDefinitions>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="8" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <TextBlock FontWeight="SemiBold" Text="操作日志" />
                                                    <TextBlock Margin="0,4,0,0"
                                                               Style="{StaticResource CaptionTextStyle}"
                                                               Text="{Binding OperationLogCountText}" />
                                                </StackPanel>
                                                <ui:Button Grid.Column="1"
                                                           Width="72"
                                                           Height="30"
                                                           Command="{Binding ClearOperationLogsCommand}"
                                                           Content="清空"
                                                           Icon="{ui:SymbolIcon Delete24}" />
                                                <ui:Button Grid.Column="3"
                                                           Width="72"
                                                           Height="30"
                                                           Command="{Binding CloseOperationLogCommand}"
                                                           Content="关闭"
                                                           Icon="{ui:SymbolIcon Dismiss24}" />
                                            </Grid>

                                            <Grid Grid.Row="1"
                                                  Margin="0,12,0,0">
                                                <TextBlock HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           Style="{StaticResource CaptionTextStyle}"
                                                           Text="暂无操作日志"
                                                           Visibility="{Binding OperationLogEmptyVisibility}" />
                                                <ListBox MaxHeight="400"
                                                         ItemContainerStyle="{StaticResource MapEditorListBoxItemStyle}"
                                                         ItemsSource="{Binding OperationLogs}"
                                                         Style="{StaticResource MapEditorListBoxStyle}"
                                                         Visibility="{Binding OperationLogListVisibility}">
                                                    <ListBox.ItemTemplate>
                                                        <DataTemplate>
                                                            <Grid>
                                                                <Grid.RowDefinitions>
                                                                    <RowDefinition Height="Auto" />
                                                                    <RowDefinition Height="Auto" />
                                                                </Grid.RowDefinitions>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="64" />
                                                                    <ColumnDefinition Width="*" />
                                                                </Grid.ColumnDefinitions>
                                                                <TextBlock FontFamily="Consolas"
                                                                           Foreground="{StaticResource MapEditorAccentBrush}"
                                                                           Text="{Binding TimeText}" />
                                                                <TextBlock Grid.Column="1"
                                                                           FontWeight="SemiBold"
                                                                           Text="{Binding Message}"
                                                                           TextWrapping="Wrap" />
                                                                <TextBlock Grid.Row="1"
                                                                           Grid.Column="1"
                                                                           Margin="0,4,0,0"
                                                                           Style="{StaticResource CaptionTextStyle}"
                                                                           Text="{Binding Context}"
                                                                           TextWrapping="Wrap" />
                                                            </Grid>
                                                        </DataTemplate>
                                                    </ListBox.ItemTemplate>
                                                </ListBox>
                                            </Grid>
                                        </Grid>
                                    </Border>
                                </Popup>

                                <Grid Grid.Row="1"
                                      Margin="0,10,0,0"
                                      Visibility="{Binding RecordedRouteListCollapsedVisibility}">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.ContextMenu>
                                        <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                            <ui:MenuItem Command="{Binding NewRecordingCommand}"
                                                         Header="新建路线"
                                                         Icon="{ui:SymbolIcon Add24}" />
                                        </ContextMenu>
                                    </Grid.ContextMenu>
                                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="路径列表" />
                                    <TextBlock Grid.Column="1"
                                               Margin="0,0,72,0"
                                               VerticalAlignment="Center"
                                               Style="{StaticResource CaptionTextStyle}"
                                               Text="{Binding RecordedRouteCountText}" />
                                    <ui:Button Grid.Column="1"
                                               Width="64"
                                               Height="28"
                                               HorizontalAlignment="Right"
                                               Command="{Binding ToggleRecordedRouteListExpandedCommand}"
                                               Content="{Binding RecordedRouteListToggleText}"
                                               Icon="{ui:SymbolIcon PanelBottomExpand20}" />
                                    <ListBox x:Name="CollapsedRecordedRouteListBox"
                                             Grid.Row="1"
                                             Grid.ColumnSpan="2"
                                             Margin="0,8,0,0"
                                             ItemContainerStyle="{StaticResource RecordedRouteListBoxItemStyle}"
                                             ItemTemplate="{StaticResource RecordedRouteListItemTemplate}"
                                             ItemsSource="{Binding CollapsedRecordedRouteItems}"
                                             MouseDoubleClick="RecordedRouteListBox_MouseDoubleClick"
                                             PreviewMouseRightButtonDown="RecordedRouteListBox_PreviewMouseRightButtonDown"
                                             SelectedItem="{Binding CollapsedRecordedRoute, Mode=OneWay}"
                                             SelectionChanged="RecordedRouteListBox_SelectionChanged"
                                             SelectionMode="Single"
                                             Style="{StaticResource MapEditorListBoxStyle}"
                                             Visibility="{Binding CollapsedRecordedRouteVisibility}">
                                        <ListBox.ContextMenu>
                                            <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                                <ui:MenuItem Command="{Binding NewRecordingCommand}"
                                                             Header="新建路线"
                                                             Icon="{ui:SymbolIcon Add24}" />
                                            </ContextMenu>
                                        </ListBox.ContextMenu>
