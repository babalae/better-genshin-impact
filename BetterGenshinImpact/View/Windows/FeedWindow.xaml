<ui:FluentWindow x:Class="BetterGenshinImpact.View.Windows.FeedWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:behavior="clr-namespace:BetterGenshinImpact.View.Behavior"
                 Width="400"
                 Height="700"
                 MinWidth="400"
                 MinHeight="250"
                 ui:Design.Background="{DynamicResource ApplicationBackgroundBrush}"
                 ui:Design.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                 ExtendsContentIntoTitleBar="True"
                 behavior:AutoTranslateInterceptor.EnableAutoTranslate="True"
                 FontFamily="{DynamicResource TextThemeFontFamily}"
                 WindowBackdropType="Mica"
                 WindowStartupLocation="CenterScreen"
                 WindowStyle="SingleBorderWindow"
                 mc:Ignorable="d">

    <ui:FluentWindow.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <DataTemplate x:Key="FeedItemTemplate">
            <ui:Card Margin="0,0,0,12"
                     Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- 标题 -->
                    <ui:TextBlock Grid.Row="0"
                                  Margin="0,0,0,8"
                                  FontSize="16"
                                  FontWeight="SemiBold"
                                  Text="{Binding Title}"
                                  TextWrapping="Wrap" />

                    <!-- 时间与有效期 -->
                    <StackPanel Grid.Row="1" Margin="0,0,0,6" Orientation="Horizontal">
                        <ui:TextBlock FontSize="12"
                                      Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}"
                                      Text="{Binding Time}" />
                        <ui:TextBlock Margin="8,0,8,0"
                                      FontSize="12"
                                      Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}"
                                      Text="  |  ">
                            <ui:TextBlock.Style>
                                <Style TargetType="{x:Type ui:TextBlock}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Valid}" Value="">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Valid}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ui:TextBlock.Style>
                        </ui:TextBlock>
                        <ui:TextBlock FontSize="12"
                                      Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}"
                                      Text="有效期至">
                            <ui:TextBlock.Style>
                                <Style TargetType="{x:Type ui:TextBlock}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Valid}" Value="">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Valid}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ui:TextBlock.Style>
                        </ui:TextBlock>
                        <ui:TextBlock Margin="4,0,0,0"
                                      FontSize="12"
                                      Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}"
                                      Text="{Binding Valid}">
                            <ui:TextBlock.Style>
                                <Style TargetType="{x:Type ui:TextBlock}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Valid}" Value="">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Valid}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ui:TextBlock.Style>
                        </ui:TextBlock>
                    </StackPanel>

                    <!-- 内容：卡片式展示 -->
                    <StackPanel Grid.Row="2"
                                Margin="0,0,0,12"
                                Visibility="{Binding Content, Converter={StaticResource BooleanToVisibilityRevertConverter}}">
                        <Border Padding="12"
                                Background="{DynamicResource ControlFillColorDefaultBrush}"
                                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="{DynamicResource ControlCornerRadius}">
                            <ui:TextBlock FontSize="14"
                                          LineHeight="20"
                                          Text="{Binding Content}"
                                          TextWrapping="Wrap" />
                        </Border>
                    </StackPanel>

                    <!-- 兑换码列表 -->
                    <StackPanel Grid.Row="3" Margin="0,0,0,8">
                        <ItemsControl ItemsSource="{Binding Codes}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,8,8"
                                            Padding="8,4"
                                            Background="{DynamicResource ControlFillColorDefaultBrush}"
                                            BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="4">
                                        <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                                            <ui:SymbolIcon Margin="0,0,6,0" Symbol="TicketDiagonal24" />
                                            <ui:TextBlock FontFamily="Consolas"
                                                          FontSize="14"
                                                          Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                          LineHeight="16"
                                                          Text="{Binding}" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- 标签 -->
                    <StackPanel Grid.Row="4"
                                Orientation="Horizontal"
                                Visibility="{Binding HasTag, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Border Background="{DynamicResource CardBackground}"
                                BorderBrush="{DynamicResource CardBorderBrush}"
                                CornerRadius="10">
                            <ui:TextBlock VerticalAlignment="Center"
                                          FontSize="11"
                                          Foreground="White"
                                          Text="{Binding Tag}" />
                        </Border>
                    </StackPanel>

                    <!-- 按钮组 -->
                    <StackPanel Grid.Row="5"
                                Margin="0,0,0,8"
                                Orientation="Horizontal">
                        <ui:Button Margin="0,0,8,0"
                                   Padding="12,6"
                                   Appearance="Secondary"
                                   Command="{Binding DataContext.CopyItemCodesCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                   CommandParameter="{Binding}"
                                   Content="复制"
                                   FontSize="12" />
                        <ui:Button Padding="12,6"
                                   Appearance="Primary"
                                   Command="{Binding DataContext.AutoRedeemItemCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                   CommandParameter="{Binding}"
                                   Content="一键兑换"
                                   FontSize="12" />
                    </StackPanel>
                </Grid>
            </ui:Card>
        </DataTemplate>
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 标题栏 -->
        <ui:TitleBar Name="MyTitleBar" Grid.Row="0" Title="兑换码">
            <ui:TitleBar.Icon>
                <ui:ImageIcon Source="pack://application:,,,/Resources/Images/logo.png" />
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <!-- 主要内容区域 -->
        <Grid Grid.Row="1" Margin="20,10,20,10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- 标题和描述 -->
            <StackPanel Grid.Row="0" Margin="0,0,0,15">
                <ui:TextBlock Margin="0,0,0,5"
                              FontSize="24"
                              FontWeight="SemiBold"
                              Text="最新兑换码动态" />
                <ui:TextBlock FontSize="14"
                              Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"
                              Text="查看最新的原神兑换码，一键自动兑换"
                              TextWrapping="Wrap" />
            </StackPanel>

            <!-- 加载状态 -->
            <StackPanel Grid.Row="1"
                        Height="16"
                        Margin="0,0,0,10"
                        VerticalAlignment="Top"
                        Orientation="Horizontal"
                        Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
                <ui:ProgressRing Width="16"
                                 Height="16"
                                 Margin="0,0,8,0"
                                 IsIndeterminate="True" />
                <ui:TextBlock Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}" Text="正在加载兑换码..." />
            </StackPanel>

            <!-- 服务器切页 -->
            <Grid Grid.Row="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <UniformGrid Grid.Row="0"
                             Margin="0,0,0,12"
                             Rows="1">
                    <ui:Button Margin="0,0,4,0"
                               HorizontalAlignment="Stretch"
                               HorizontalContentAlignment="Center"
                               Command="{Binding SelectCnServerCommand}"
                               Content="国服"
                               Icon="{ui:SymbolIcon TicketDiagonal24}">
                        <ui:Button.Style>
                            <Style TargetType="{x:Type ui:Button}" BasedOn="{StaticResource {x:Type ui:Button}}">
                                <Setter Property="Appearance" Value="Secondary" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsCnServerSelected}" Value="True">
                                        <Setter Property="Appearance" Value="Primary" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ui:Button.Style>
                    </ui:Button>

                    <ui:Button Margin="4,0,0,0"
                               HorizontalAlignment="Stretch"
                               HorizontalContentAlignment="Center"
                               Command="{Binding SelectGlobalServerCommand}"
                               Content="国际服"
                               Icon="{ui:SymbolIcon CloudArrowUp24}">
                        <ui:Button.Style>
                            <Style TargetType="{x:Type ui:Button}" BasedOn="{StaticResource {x:Type ui:Button}}">
                                <Setter Property="Appearance" Value="Secondary" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsGlobalServerSelected}" Value="True">
                                        <Setter Property="Appearance" Value="Primary" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ui:Button.Style>
                    </ui:Button>
                </UniformGrid>

                <Grid Grid.Row="1">
                    <Grid Visibility="{Binding IsCnServerSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Margin="0,0,0,12"
                                Padding="12"
                                Background="{DynamicResource ControlFillColorDefaultBrush}"
                                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0"
                                        Width="32"
                                        Height="32"
                                        Margin="0,0,10,0"
                                        Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                        CornerRadius="6">
                                    <ui:SymbolIcon HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Symbol="Alert24" />
                                </Border>

                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <ui:TextBlock FontTypography="BodyStrong"
                                                  Text="兑换码更新通知" />
                                    <ui:TextBlock Margin="0,3,0,0"
                                                  Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}"
                                                  Text="开启后有新的国服兑换码时提醒"
                                                  TextWrapping="Wrap" />
                                </StackPanel>

                                <ui:ToggleSwitch Grid.Column="2"
                                                 Margin="12,0,4,0"
                                                 VerticalAlignment="Center"
                                                 IsChecked="{Binding CommonConfig.RedeemCodeCnFeedsNotificationEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                        </Border>

                        <ScrollViewer Grid.Row="1"
                                      HorizontalScrollBarVisibility="Disabled"
                                      VerticalScrollBarVisibility="Auto">
                            <ItemsControl Padding="0,0,16,0"
                                          ItemTemplate="{StaticResource FeedItemTemplate}"
                                          ItemsSource="{Binding CnFeedItems}" />
                        </ScrollViewer>
                    </Grid>

                    <Grid Visibility="{Binding IsGlobalServerSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Margin="0,0,0,12"
                                Padding="12"
                                Background="{DynamicResource ControlFillColorDefaultBrush}"
                                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0"
                                        Width="32"
                                        Height="32"
                                        Margin="0,0,10,0"
                                        Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                        CornerRadius="6">
                                    <ui:SymbolIcon HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Symbol="Alert24" />
                                </Border>

                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <ui:TextBlock FontTypography="BodyStrong"
                                                  Text="兑换码更新通知" />
                                    <ui:TextBlock Margin="0,3,0,0"
                                                  Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}"
                                                  Text="开启后有新的国际服兑换码时提醒"
                                                  TextWrapping="Wrap" />
                                </StackPanel>

                                <ui:ToggleSwitch Grid.Column="2"
                                                 Margin="12,0,4,0"
                                                 VerticalAlignment="Center"
                                                 IsChecked="{Binding CommonConfig.RedeemCodeGlobalFeedsNotificationEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                        </Border>

                        <ScrollViewer Grid.Row="1"
                                      HorizontalScrollBarVisibility="Disabled"
                                      VerticalScrollBarVisibility="Auto">
                            <ItemsControl Padding="0,0,16,0"
                                          ItemTemplate="{StaticResource FeedItemTemplate}"
                                          ItemsSource="{Binding GlobalFeedItems}" />
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>

        <!-- 底部按钮 -->
        <Grid Grid.Row="2" Margin="40,10,20,20">
            <StackPanel HorizontalAlignment="Right"
                        Orientation="Horizontal">
                <ui:Button Name="BtnGetLiveCodes"
                           Margin="0,0,10,0"
                           Appearance="Secondary"
                           Command="{Binding GetLiveRedeemCodesCommand}"
                           Content="实时获取前瞻兑换码">
                    <ui:Button.Style>
                        <Style TargetType="{x:Type ui:Button}" BasedOn="{StaticResource {x:Type ui:Button}}">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding IsDisplayBtnGetLiveCodes}" Value="True" />
                                        <Condition Binding="{Binding IsCnServerSelected}" Value="True" />
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Visible" />
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ui:Button.Style>
                </ui:Button>
                <ui:Button Name="BtnClose"
                           Click="BtnCloseClick"
                           Content="关闭" />
            </StackPanel>
        </Grid>
    </Grid>
</ui:FluentWindow>
